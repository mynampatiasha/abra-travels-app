      console.log('\n🌍 Reverse geocoding locations...');
      
      let pickupAddress = 'Not specified';
      let dropAddress = 'Not specified';
      
      // Helper function for reverse geocoding - returns only readable address
      const reverseGeocode = async (lat, lng) => {
        try {
          const response = await fetch(
            `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=18&addressdetails=1`,
            {
              headers: {
                'User-Agent': 'AbraFleet/1.0'
              }
            }
          );
          const data = await response.json();
          
          if (data && data.address) {
            // Build a clean address without coordinates
            const address = data.address;
            const parts = [];
            
            if (address.road) parts.push(address.road);
            if (address.suburb) parts.push(address.suburb);
            if (address.city || address.town || address.village) {
              parts.push(address.city || address.town || address.village);
            }
            if (address.state) parts.push(address.state);
            
            return parts.length > 0 ? parts.join(', ') : data.display_name;
          }
          
          return 'Location not available';
        } catch (error) {
          console.error('Reverse geocoding error:', error);
          return 'Location not available';
        }
      };
      
      // Get pickup location
      if (roster.locations?.pickup?.coordinates) {
        const coords = roster.locations.pickup.coordinates;
        if (roster.locations.pickup.address && 
            !roster.locations.pickup.address.includes(',') && 
            roster.locations.pickup.address.length < 50) {
          // If existing address looks like coordinates or is too short, reverse geocode
          pickupAddress = await reverseGeocode(coords.latitude, coords.longitude);
        } else {
          pickupAddress = roster.locations.pickup.address || 
                         await reverseGeocode(coords.latitude, coords.longitude);
        }
      } else if (roster.locations?.loginPickup?.coordinates) {
        const coords = roster.locations.loginPickup.coordinates;
        if (roster.locations.loginPickup.address && 
            !roster.locations.loginPickup.address.includes(',') && 
            roster.locations.loginPickup.address.length < 50) {
          pickupAddress = await reverseGeocode(coords.latitude, coords.longitude);
        } else {
          pickupAddress = roster.locations.loginPickup.address || 
