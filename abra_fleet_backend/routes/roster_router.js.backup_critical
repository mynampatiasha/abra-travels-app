Customer: ${roster.customerName}
Office: ${roster.officeLocation}
Type: ${rosterTypeText}
Date: ${formattedStartDate} to ${formattedEndDate}
Time: ${roster.startTime} - ${roster.endTime}

Vehicle: ${vehicle.registrationNumber}

Pickup Location: ${pickupAddress}
Drop Location: ${dropAddress}`.trim();

