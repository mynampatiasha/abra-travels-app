        if (roster.locations.drop.address && 
            !roster.locations.drop.address.includes(',') && 
            roster.locations.drop.address.length < 50) {
          dropAddress = await reverseGeocode(coords.latitude, coords.longitude);
        } else {
          dropAddress = roster.locations.drop.address || 
                       await reverseGeocode(coords.latitude, coords.longitude);
        }
      } else if (roster.locations?.logoutDrop?.coordinates) {
        const coords = roster.locations.logoutDrop.coordinates;
        if (roster.locations.logoutDrop.address && 
            !roster.locations.logoutDrop.address.includes(',') && 
            roster.locations.logoutDrop.address.length < 50) {
          dropAddress = await reverseGeocode(coords.latitude, coords.longitude);
        } else {
          dropAddress = roster.locations.logoutDrop.address || 
                       await reverseGeocode(coords.latitude, coords.longitude);
        }
      }
      
      console.log('✅ Locations geocoded');
      console.log('   Pickup:', pickupAddress);
      console.log('   Drop:', dropAddress);

      // ✅ UPDATE ROSTER IN MONGODB
      const updateData = {
        assignedDriver: {
          driverId: driver._id,
          name: driverName,
          phone: driverPhone || null,
          assignedAt: new Date(),
          assignedBy: req.user.uid
        },
        assignedVehicle: {
          vehicleId: vehicle._id,
          registrationNumber: vehicle.registrationNumber,
          make: vehicle.make || null,
          model: vehicle.model || null,
          assignedAt: new Date()
        },
        assignedDriverId: driver._id,
        assignedDriverName: driverName,
        assignedVehicleId: vehicle._id,
        assignedVehicleReg: vehicle.registrationNumber,
        status: roster.status === 'pending_assignment' ? 'assigned' : roster.status,
        assignmentDate: new Date(),
        updatedAt: new Date(),
        lastModifiedBy: req.user.uid
      };

      const result = await req.db.collection('rosters').findOneAndUpdate(
        { _id: rosterObjectId },
        { $set: updateData },
        { returnDocument: 'after' }
      );

      const updatedDoc = result.value || result;
      const finalDoc = updatedDoc && updatedDoc._id ? updatedDoc : 
        (await req.db.collection('rosters').findOne({ _id: rosterObjectId }));

      console.log('✅ Roster updated in MongoDB');

      // ✅ UPDATE FIREBASE
      try {
        const firebaseDb = admin.database();
        await firebaseDb.ref('roster_requests').child(rosterId).update({
          status: finalDoc.status,
          assignedDriverId: driver._id.toString(),
          assignedVehicleId: vehicle._id.toString(),
          assignedDriverName: driverName,
          assignedDriverPhone: driverPhone || null,
          assignedVehicleReg: vehicle.registrationNumber,
          assignmentDate: new Date().toISOString(),
          updatedAt: new Date().toISOString(),
          lastModifiedBy: req.user.uid
        });
        console.log('✅ Firebase updated');
      } catch (firebaseError) {
        console.log('⚠️  Firebase update failed:', firebaseError.message);
