      // ✅ VALIDATE IDs
      if (!ObjectId.isValid(rosterId)) {
        return res.status(400).json({
          success: false,
          message: 'Invalid roster ID format'
        });
      }

      const rosterObjectId = new ObjectId(rosterId);

      // ✅ FETCH ROSTER
      const roster = await req.db.collection('rosters').findOne({
        _id: rosterObjectId
      });

