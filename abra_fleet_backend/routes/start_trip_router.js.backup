// ============================================================================
// @route   POST /api/trips/:tripId/end
// @desc    End individual trip with final odometer photo
// @access  Private (Driver)
// ============================================================================
router.post('/:tripId/end', verifyToken, upload.single('photo'), async (req, res) => {
  try {
    console.log('\n' + '='.repeat(80));
    console.log('🏁 ENDING INDIVIDUAL TRIP');
    console.log('='.repeat(80));
    
    const { tripId } = req.params;
    const { reading } = req.body;
    const photo = req.file;
    
    console.log(`📋 Trip ID: ${tripId}`);
    console.log(`📏 End Odometer Reading: ${reading}`);
    console.log(`📸 Photo: ${photo ? 'Uploaded' : 'Missing'}`);
    
    if (!reading || !photo) {
      return res.status(400).json({
        success: false,
        message: 'End odometer reading and photo are required'
      });
    }
    
    const trip = await req.db.collection('trips').findOne({
      _id: new ObjectId(tripId)
    });
    
    if (!trip) {
      return res.status(404).json({
        success: false,
        message: 'Trip not found'
      });
    }
    
    console.log('📤 Uploading end odometer photo to GridFS...');
    
    const bucket = new GridFSBucket(req.db, {
      bucketName: 'odometer_photos'
    });
    
    const uploadStream = bucket.openUploadStream(`end-${tripId}-${Date.now()}.jpg`, {
      metadata: {
        tripId: tripId,
        type: 'end_odometer',
        reading: parseInt(reading),
        uploadedBy: req.user.driverId || req.user.id || req.user.uid,
        uploadedAt: new Date()
      }
    });
    
    uploadStream.end(photo.buffer);
    
    const photoId = await new Promise((resolve, reject) => {
      uploadStream.on('finish', () => resolve(uploadStream.id));
      uploadStream.on('error', reject);
    });
    
    console.log(`✅ Photo uploaded to GridFS: ${photoId}`);
    
    const startOdometer = trip.startOdometer?.reading || 0;
    const actualDistance = parseInt(reading) - startOdometer;
    
    console.log(`📏 Distance traveled: ${actualDistance} km`);
    
    const startTime = trip.actualStartTime ? new Date(trip.actualStartTime) : new Date();
    const endTime = new Date();
    const actualDuration = Math.round((endTime - startTime) / 60000);
    
    const updateResult = await req.db.collection('trips').updateOne(
      { _id: new ObjectId(tripId) },
      {
        $set: {
          status: 'completed',
          actualEndTime: endTime,
          actualDuration: actualDuration,
          actualDistance: actualDistance,
          endOdometer: {
            reading: parseInt(reading),
            photoId: photoId,
            timestamp: endTime
          },
          'statusHistory.completed': endTime,
          updatedAt: endTime
        }
      }
    );
    
    console.log(`✅ Trip updated to 'completed' status`);
    
    console.log('📤 Notifying admin...');
    
    const admin = await req.db.collection('employee_admins').findOne({
      _id: new ObjectId(trip.createdBy)
    });
    
    if (admin && admin.email) {
      try {
        await createNotification(req.db, {
          userId: admin._id.toString(),
          userEmail: admin.email,
          userRole: admin.role || 'admin',
          title: '✅ Trip Completed',
          body: `${trip.driverName} has completed trip ${trip.tripNumber}.\n\n` +
                `📏 Distance: ${actualDistance} km\n` +
                `⏱️  Duration: ${actualDuration} minutes\n` +
                `🏁 Completed: ${formatTime(endTime)}`,
          type: 'trip_completed_admin',
          data: {
            tripId: tripId,
            tripNumber: trip.tripNumber,
            driverName: trip.driverName,
            actualDistance: actualDistance,
            actualDuration: actualDuration,
            completedTime: endTime.toISOString()
          },
          priority: 'normal',
          category: 'trip_update',
          channels: ['fcm', 'database']
        });
        
        console.log(`✅ Admin notified`);
      } catch (notifError) {
        console.log(`⚠️  Admin notification failed: ${notifError.message}`);
      }
    }
    
    console.log('='.repeat(80));
    console.log('✅ TRIP COMPLETED SUCCESSFULLY');
    console.log('='.repeat(80) + '\n');
    
    res.json({
      success: true,
      message: 'Trip completed successfully',
      data: {
        tripId: tripId,
        tripNumber: trip.tripNumber,
        status: 'completed',
        endOdometer: {
          reading: parseInt(reading),
          photoId: photoId.toString()
        },
        startOdometer: startOdometer,
        actualDistance: actualDistance,
        actualDuration: actualDuration,
        completedAt: endTime.toISOString(),
        adminNotified: !!(admin && admin.email)
      }
    });
    
  } catch (error) {
    console.error('❌ Error ending trip:', error);
    res.status(500).json({
      success: false,
      message: 'Failed to end trip',
      error: error.message
    });
  }
});

// ============================================================================
// @route   POST /api/trips/:tripGroupId/stop/:stopId/arrive
// @desc    Mark driver arrived at stop (pickup or drop location)
// @access  Private (Driver)
// ============================================================================
router.post('/:tripGroupId/stop/:stopId/arrive', verifyToken, async (req, res) => {
  try {
    console.log('\n' + '='.repeat(80));
    console.log(`📍 DRIVER ARRIVED AT STOP`);
    console.log('='.repeat(80));
    
    const { tripGroupId, stopId } = req.params;
    const { latitude, longitude } = req.body;
    
    console.log(`🆔 Trip Group ID: ${tripGroupId}`);
    console.log(`📍 Stop ID: ${stopId}`);
    
    const trip = await req.db.collection('trips').findOne({
      tripNumber: tripGroupId
    });
    
    if (!trip) {
      console.log('❌ Trip not found');
      return res.status(404).json({
        success: false,
        message: 'Trip not found. Please refresh and try again.'
      });
    }
    
    console.log(`✅ Trip found: ${trip.tripNumber}`);
    console.log(`   Status: ${trip.status}`);
    
    const updateResult = await req.db.collection('trips').updateOne(
      { tripNumber: tripGroupId },
      {
        $set: {
          status: 'in_progress',
          arrivedAt: new Date(),
          arrivalLocation: latitude && longitude ? {
            latitude: parseFloat(latitude),
            longitude: parseFloat(longitude),
            timestamp: new Date()
          } : null,
          updatedAt: new Date()
        }
      }
    );
    
    if (updateResult.matchedCount === 0) {
      console.log('❌ Failed to update trip');
      return res.status(500).json({
        success: false,
        message: 'Failed to update trip status'
      });
    }
    
    console.log(`✅ Trip status updated to 'in_progress'`);
    
    if (trip.customer && trip.customer.email) {
      console.log(`\n📍 SENDING ARRIVAL NOTIFICATION TO CUSTOMER`);
      console.log('='.repeat(60));
      
      try {
        const customer = await req.db.collection('customers').findOne({
          email: trip.customer.email
        });
        
        if (customer) {
          console.log(`✅ Customer found: ${customer.name || customer.email}`);
          
          const driver = await req.db.collection('drivers').findOne({
            driverId: trip.driverId
          });
          
          const driverName = driver?.personalInfo?.name || driver?.name || trip.driverName || 'Your driver';
          const driverPhone = driver?.personalInfo?.phone || driver?.phone || trip.driverPhone || '';
          
          const notification = {
            userId: customer._id,
            userEmail: customer.email,
            userRole: 'customer',
            type: 'driver_arrived',
            title: '📍 Driver Has Arrived!',
            body: `${driverName} is waiting at your pickup location`,
            message: `Your driver ${driverName} has arrived at your location.\n\nVehicle: ${trip.vehicleNumber}\nPhone: ${driverPhone}\n\nPlease proceed to the vehicle.`,
            data: {
              tripId: trip._id.toString(),
              tripNumber: trip.tripNumber,
              driverName: driverName,
              driverPhone: driverPhone,
              vehicleNumber: trip.vehicleNumber,
              pickupAddress: trip.pickupLocation?.address || 'Your location',
            },
            priority: 'urgent',
            category: 'trip_updates',
            isRead: false,
            createdAt: new Date(),
            updatedAt: new Date(),
            expiresAt: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000),
            deliveryStatus: {
              fcm: 'pending',
              database: 'success'
            },
            channels: ['database']
          };
          
          await req.db.collection('notifications').insertOne(notification);
          console.log(`✅ Arrival notification created`);
        }
      } catch (notificationError) {
        console.log(`⚠️  Notification error: ${notificationError.message}`);
      }
      
      console.log('='.repeat(60));
    }
    
    console.log('='.repeat(80) + '\n');
    
    res.json({
      success: true,
      message: 'Marked as arrived and customer notified',
      data: {
        tripId: trip._id.toString(),
        tripNumber: trip.tripNumber,
        status: 'in_progress',
        arrivedAt: new Date(),
        customerNotified: true
      }
    });
    
  } catch (error) {
    console.error('❌ Error marking arrival:', error);
    res.status(500).json({
      success: false,
      message: 'Failed to mark arrival',
      error: error.message
    });
  }
});

// ============================================================================
// @route   POST /api/trips/:tripGroupId/stop/:stopId/depart
// @desc    Mark departure from stop and request feedback
// @access  Private (Driver)
// ============================================================================
router.post('/:tripGroupId/stop/:stopId/depart', verifyToken, async (req, res) => {
  try {
    console.log('\n' + '='.repeat(80));
    console.log('🚗 DEPARTING FROM STOP');
    console.log('='.repeat(80));
    
    const { tripGroupId, stopId } = req.params;
    const { latitude, longitude } = req.body;
    
    console.log(`🆔 Trip Group ID: ${tripGroupId}`);
    console.log(`📍 Stop ID: ${stopId}`);
    
    const trip = await req.db.collection('trips').findOne({
      tripNumber: tripGroupId
    });
    
    if (!trip) {
      return res.status(404).json({
        success: false,
        message: 'Trip not found'
      });
    }
    
    console.log(`✅ Trip found: ${trip.tripNumber}`);
    
    const updateResult = await req.db.collection('trips').updateOne(
      { tripNumber: tripGroupId },
      {
        $set: {
          status: 'in_progress',
          departedAt: new Date(),
          departureLocation: latitude && longitude ? {
            latitude: parseFloat(latitude),
            longitude: parseFloat(longitude),
            timestamp: new Date()
          } : null,
          updatedAt: new Date()
        }
      }
    );
    
    if (updateResult.matchedCount === 0) {
      return res.status(500).json({
        success: false,
        message: 'Failed to update trip'
      });
    }
    
    console.log(`✅ Trip updated - marked as departed`);
    
    if (trip.customer && trip.customer.email) {
      console.log('\n⭐ REQUESTING CUSTOMER FEEDBACK');
      console.log('='.repeat(60));
      
      try {
        const customer = await req.db.collection('customers').findOne({
          email: trip.customer.email
        });
        
        if (customer) {
          console.log(`✅ Customer found: ${customer.name || customer.email}`);
          
          const driver = await req.db.collection('drivers').findOne({
            driverId: trip.driverId
          });
          
          const driverName = driver?.personalInfo?.name || driver?.name || trip.driverName || 'Your driver';
          
          const feedbackRequest = await req.db.collection('feedback_requests').insertOne({
            tripId: trip._id,
            tripNumber: trip.tripNumber,
            customerId: customer._id,
            customerEmail: customer.email,
            driverId: trip.driverId,
            driverName: driverName,
            requestedAt: new Date(),
            status: 'pending',
            feedbackGiven: false,
            expiresAt: new Date(Date.now() + 24 * 60 * 60 * 1000),
          });
          
          console.log(`✅ Feedback request saved: ${feedbackRequest.insertedId}`);
          
          const notification = {
            userId: customer._id,
            userEmail: customer.email,
            userRole: 'customer',
            type: 'feedback_request',
            title: '⭐ How was your ride?',
            body: `Please rate your experience with ${driverName}`,
            message: `Hi ${customer.name},\n\nYour trip has been completed. We'd love to hear about your experience!\n\nPlease take a moment to rate your ride with ${driverName}.`,
            data: {
              tripId: trip._id.toString(),
              tripNumber: trip.tripNumber,
              driverName: driverName,
              driverId: trip.driverId,
              feedbackRequestId: feedbackRequest.insertedId.toString(),
              action: 'open_feedback',
            },
            priority: 'high',
            category: 'feedback',
            isRead: false,
            createdAt: new Date(),
            updatedAt: new Date(),
            expiresAt: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000),
            deliveryStatus: {
              fcm: 'pending',
              database: 'success'
            },
            channels: ['database']
          };
          
          await req.db.collection('notifications').insertOne(notification);
          console.log(`✅ Feedback request notification created`);
        }
      } catch (feedbackError) {
        console.log(`⚠️ Feedback error: ${feedbackError.message}`);
      }
      
      console.log('='.repeat(60));
    }
    
    console.log('='.repeat(80) + '\n');
    
    res.json({
      success: true,
      message: 'Marked as departed and feedback requested',
      data: {
        tripId: trip._id.toString(),
        tripNumber: trip.tripNumber,
        status: 'in_progress',
        departedAt: new Date(),
        feedbackRequested: true
      }
    });
    
  } catch (error) {
    console.error('❌ Error marking departure:', error);
    res.status(500).json({
      success: false,
      message: 'Failed to mark departure',
      error: error.message
    });
  }
});

// ============================================================================
// @route   POST /api/trips/:tripGroupId/end
// @desc    End trip with odometer photo
// @access  Private (Driver)
// ============================================================================
router.post('/:tripGroupId/end', verifyToken, upload.single('photo'), async (req, res) => {
  try {
    console.log('\n' + '='.repeat(80));
    console.log('🏁 ENDING TRIP');
    console.log('='.repeat(80));
    
    const { tripGroupId } = req.params;
    const { reading } = req.body;
    const photo = req.file;
    
    console.log(`📋 Trip Number: ${tripGroupId}`);
    console.log(`📏 End Odometer Reading: ${reading}`);
    console.log(`📸 Photo: ${photo ? 'Uploaded' : 'Missing'}`);
    
    if (!reading || !photo) {
      return res.status(400).json({
        success: false,
        message: 'End odometer reading and photo are required'
      });
    }
    
    const trip = await req.db.collection('trips').findOne({
      tripNumber: tripGroupId
    });
    
    if (!trip) {
      return res.status(404).json({
        success: false,
        message: 'Trip not found'
      });
    }
    
    console.log(`✅ Trip found: ${trip.tripNumber}`);
    
    console.log('📤 Uploading end odometer photo to GridFS...');
    
    const bucket = new GridFSBucket(req.db, {
      bucketName: 'odometer_photos'
    });
    
    const uploadStream = bucket.openUploadStream(`end-${tripGroupId}-${Date.now()}.jpg`, {
      metadata: {
        tripNumber: tripGroupId,
        type: 'end_odometer',
        reading: parseInt(reading),
        uploadedBy: req.user.driverId || req.user.id,
        uploadedAt: new Date()
      }
    });
    
    uploadStream.end(photo.buffer);
    
    const photoId = await new Promise((resolve, reject) => {
      uploadStream.on('finish', () => resolve(uploadStream.id));
      uploadStream.on('error', reject);
    });
    
    console.log(`✅ Photo uploaded to GridFS: ${photoId}`);
    
    const startReading = trip.startOdometer?.reading || 0;
    const endReading = parseInt(reading);
    const actualDistance = endReading - startReading;
    
    console.log(`📏 Distance: ${startReading} → ${endReading} = ${actualDistance} km`);
    
    const updateResult = await req.db.collection('trips').updateOne(
      { tripNumber: tripGroupId },
      {
        $set: {
          status: 'completed',
          endOdometer: {
            reading: endReading,
            photoId: photoId,
            timestamp: new Date()
          },
          actualDistance: actualDistance,
          actualEndTime: new Date(),
          actualDuration: trip.actualStartTime ? 
            Math.round((new Date() - new Date(trip.actualStartTime)) / 60000) : null,
          updatedAt: new Date()
        }
      }
    );
    
    if (updateResult.matchedCount === 0) {
      return res.status(500).json({
        success: false,
        message: 'Failed to update trip'
      });
    }
    
    console.log(`✅ Trip marked as completed`);
    
    if (trip.customer && trip.customer.email) {
      try {
        const customer = await req.db.collection('customers').findOne({
          email: trip.customer.email
        });
        
        if (customer) {
          const notification = {
            userId: customer._id,
            userEmail: customer.email,
            userRole: 'customer',
            type: 'trip_completed',
            title: '✅ Trip Completed',
            body: `Your trip has been completed successfully`,
            message: `Thank you for traveling with us!\n\nTrip: ${trip.tripNumber}\nDistance: ${actualDistance} km\nDuration: ${trip.actualDuration || 'N/A'} minutes`,
            data: {
              tripId: trip._id.toString(),
              tripNumber: trip.tripNumber,
              distance: actualDistance,
              duration: trip.actualDuration
            },
            priority: 'normal',
            category: 'trip_updates',
            isRead: false,
            createdAt: new Date(),
            updatedAt: new Date(),
            expiresAt: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000),
            deliveryStatus: {
              fcm: 'pending',
              database: 'success'
            },
            channels: ['database']
          };
          
          await req.db.collection('notifications').insertOne(notification);
          console.log(`✅ Completion notification created`);
        }
      } catch (notificationError) {
        console.log(`⚠️ Notification error: ${notificationError.message}`);
      }
    }
    
    console.log('='.repeat(80) + '\n');
    
    res.json({
      success: true,
      message: 'Trip completed successfully!',
      data: {
        tripId: trip._id.toString(),
        tripNumber: trip.tripNumber,
        status: 'completed',
        endOdometer: {
          reading: endReading,
          photoId: photoId.toString()
        },
        actualDistance: actualDistance,
        actualDuration: trip.actualDuration,
        completedAt: new Date()
      }
    });
    
  } catch (error) {
    console.error('❌ Error ending trip:', error);
    res.status(500).json({
      success: false,
      message: 'Failed to end trip',
      error: error.message
    });
  }
});

// ============================================================================
// @route   POST /api/trips/:tripGroupId/location
// @desc    Update driver's real-time GPS location
// @access  Private (Driver)
// ============================================================================
router.post('/:tripGroupId/location', verifyToken, async (req, res) => {
  try {
    const { tripGroupId } = req.params;
    const { latitude, longitude, speed, heading } = req.body;
    
    if (!latitude || !longitude) {
      return res.status(400).json({
        success: false,
        message: 'Latitude and longitude are required'
      });
    }
    
    const location = {
      latitude: parseFloat(latitude),
      longitude: parseFloat(longitude),
      speed: speed ? parseFloat(speed) : null,
      heading: heading ? parseFloat(heading) : null,
      timestamp: new Date()
    };
    
    const updateResult = await req.db.collection('trips').updateOne(
      { tripNumber: tripGroupId },
      {
        $set: {
          currentLocation: location,
          updatedAt: new Date()
        },
        $push: {
          locationHistory: {
            $each: [location],
            $slice: -100
          }
        }
      }
    );
    
    if (updateResult.matchedCount === 0) {
      return res.status(404).json({
        success: false,
        message: 'Trip not found'
      });
    }
    
    res.json({
      success: true,
      message: 'Location updated',
      data: {
        location: location
      }
    });
    
  } catch (error) {
    console.error('❌ Error updating location:', error);
    res.status(500).json({
      success: false,
      message: 'Failed to update location',
      error: error.message
    });
  }
});

module.exports = router;