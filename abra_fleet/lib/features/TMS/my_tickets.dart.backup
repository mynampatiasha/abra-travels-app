                  Text(
                    'Filters',
                    style: TextStyle(fontSize: 20, fontWeight: FontWeight.bold, color: darkBlue),
                  ),
                  const Spacer(),
                  IconButton(
                    icon: const Icon(Icons.close, color: Color(0xFF64748B)),
                    onPressed: () => Navigator.pop(context),
                  ),
                ],
              ),
              const SizedBox(height: 24),
              Text(
                'Status',
                style: TextStyle(color: darkBlue, fontWeight: FontWeight.w600, fontSize: 14),
              ),
              const SizedBox(height: 8),
              _buildStatusFilterButtons(),
              const SizedBox(height: 20),
              Text(
                'Priority',
                style: TextStyle(color: darkBlue, fontWeight: FontWeight.w600, fontSize: 14),
              ),
              const SizedBox(height: 8),
              _buildPriorityFilterButtons(),
              const SizedBox(height: 20),
              Text(
                'Date Range',
                style: TextStyle(color: darkBlue, fontWeight: FontWeight.w600, fontSize: 14),
              ),
              const SizedBox(height: 8),
              Row(
                children: [
                  Expanded(
                    child: _buildDateButton('From', _dateFrom, (date) {
                      setState(() => _dateFrom = date);
                    }),
                  ),
                  const SizedBox(width: 12),
                  Expanded(
                    child: _buildDateButton('To', _dateTo, (date) {
                      setState(() => _dateTo = date);
                    }),
                  ),
                ],
              ),
              const SizedBox(height: 24),
