// ============================================================================
// MY TICKETS SCREEN - Table Layout with Export Functionality
// ============================================================================
// Features:
// - Table layout with horizontal and vertical scrolling
// - Proper cell spacing and padding
// - Export to Excel functionality (like invoices_list_page.dart)
// - Filters and search
// - Responsive design
// ============================================================================

import 'package:flutter/material.dart';
import 'package:intl/intl.dart';
import 'package:abra_fleet/core/services/tms_service.dart';
import 'package:abra_fleet/core/utils/export_helper.dart';
import 'package:abra_fleet/features/TMS/ticket_detail_screen.dart';

class MyTicketsScreen extends StatefulWidget {
  const MyTicketsScreen({Key? key}) : super(key: key);

  @override
  State<MyTicketsScreen> createState() => _MyTicketsScreenState();
}

class _MyTicketsScreenState extends State<MyTicketsScreen>
    with SingleTickerProviderStateMixin {
  final _tmsService = TMSService();
  final _searchController = TextEditingController();

  // Custom color scheme
  static const Color darkBlue = Color(0xFF042E45);
  static const Color mediumBlue = Color(0xFF186285);
  static const Color lightBlue = Color(0xFFEBF2F5);
  static const Color accentBlue = Color(0xFF186285);

  List<Map<String, dynamic>> _tickets = [];
  List<Map<String, dynamic>> _filteredTickets = [];
  bool _isLoading = true;
  bool _isExporting = false;

  String _statusFilter = 'active';
  String _priorityFilter = 'all';
  String _searchQuery = '';
  DateTime? _dateFrom;
  DateTime? _dateTo;

  int _openCount = 0;
  int _inProgressCount = 0;
  int _closedCount = 0;
  int _highPriorityCount = 0;

  late AnimationController _pulseController;
  late Animation<double> _pulseAnimation;

  @override
  void initState() {
    super.initState();
    _setupAnimation();
    _fetchTickets();
  }

  @override
  void dispose() {
    _searchController.dispose();
    _pulseController.dispose();
    super.dispose();
  }

  void _setupAnimation() {
    _pulseController = AnimationController(
      duration: const Duration(milliseconds: 1500),
      vsync: this,
    )..repeat(reverse: true);

    _pulseAnimation = Tween<double>(begin: 0.7, end: 1.0).animate(
      CurvedAnimation(parent: _pulseController, curve: Curves.easeInOut),
    );
  }

  Future<void> _fetchTickets() async {
    setState(() => _isLoading = true);

    final response = await _tmsService.fetchMyTickets(
      status: _statusFilter == 'all' ? null : _statusFilter,
    );

    if (response['success'] == true && response['data'] != null) {
      setState(() {
        _tickets = List<Map<String, dynamic>>.from(response['data']);
        _applyFilters();
        _calculateStatistics();
        _isLoading = false;
      });
    } else {
      setState(() => _isLoading = false);
      _showErrorSnackbar('Failed to load tickets');
    }
  }

  void _applyFilters() {
    setState(() {
      _filteredTickets = _tickets.where((ticket) {
        if (_searchQuery.isNotEmpty) {
          final subject = ticket['subject']?.toString().toLowerCase() ?? '';
          final ticketNumber = ticket['ticket_number']?.toString().toLowerCase() ?? '';
          final message = ticket['message']?.toString().toLowerCase() ?? '';
          final query = _searchQuery.toLowerCase();

          if (!subject.contains(query) && !ticketNumber.contains(query) && !message.contains(query)) {
            return false;
          }
        }

        if (_priorityFilter != 'all') {
          final priority = ticket['priority']?.toString() ?? '';
          if (priority != _priorityFilter) return false;
        }

        if (_dateFrom != null || _dateTo != null) {
          final createdAt = ticket['created_at'];
          if (createdAt == null) return false;

          final date = DateTime.tryParse(createdAt);
          if (date == null) return false;

          if (_dateFrom != null && date.isBefore(_dateFrom!)) return false;
          if (_dateTo != null) {
            final endDate = DateTime(_dateTo!.year, _dateTo!.month, _dateTo!.day, 23, 59, 59);
            if (date.isAfter(endDate)) return false;
          }
        }

        return true;
      }).toList();
    });
  }

  void _calculateStatistics() {
    _openCount = 0;
    _inProgressCount = 0;
    _closedCount = 0;
    _highPriorityCount = 0;

    for (final ticket in _tickets) {
      final status = ticket['status']?.toString() ?? '';
      final priority = ticket['priority']?.toString().toLowerCase() ?? '';

      if (status == 'Open') _openCount++;
      if (status == 'In Progress') _inProgressCount++;
      if (status == 'closed') _closedCount++;
      if (priority == 'high') _highPriorityCount++;
    }
  }

  // ============================================================================
  // EXPORT TO EXCEL - Works exactly like invoices_list_page.dart
  // ============================================================================
  Future<void> _exportToExcel() async {
    try {
      // Check if there are tickets to export
      if (_filteredTickets.isEmpty) {
        _showErrorSnackbar('No tickets to export');
        return;
      }

      setState(() => _isExporting = true);
      _showSuccessSnackbar('Preparing Excel export...');

      // Prepare data for export
      List<List<dynamic>> csvData = [
        // Headers
        [
          'Ticket Number',
          'Subject',
          'Message',
          'Priority',
          'Status',
          'Timeline',
          'Deadline',
          'Created At',
          'Created By',
          'Assigned To',
        ],
      ];

      print('📊 Exporting ${_filteredTickets.length} tickets...');

      // Add data rows
      for (var ticket in _filteredTickets) {
        csvData.add([
          ticket['ticket_number'] ?? 'N/A',
          ticket['subject'] ?? 'No Subject',
          ticket['message'] ?? '',
          ticket['priority'] ?? 'Medium',
          ticket['status'] ?? 'Open',
          _formatTimelineForExport(ticket['timeline']),
          _formatDateForExport(ticket['deadline']),
          _formatDateForExport(ticket['created_at']),
          ticket['created_by_name'] ?? 'N/A',
          ticket['assigned_to_name'] ?? 'Not Assigned',
        ]);
      }

      // Use ExportHelper to export
      final filePath = await ExportHelper.exportToExcel(
        data: csvData,
        filename: 'my_tickets',
      );

      setState(() => _isExporting = false);
      _showSuccessSnackbar('✅ Excel file downloaded with ${_filteredTickets.length} tickets!');
    } catch (e) {
      setState(() => _isExporting = false);
      print('❌ Export Error: $e');
      _showErrorSnackbar('Failed to export: $e');
    }
  }

  String _formatTimelineForExport(int? minutes) {
    if (minutes == null || minutes <= 0) return 'Not Set';
    if (minutes < 60) return '$minutes min';
    if (minutes < 1440) {
      final hours = (minutes / 60).floor();
      return '$hours hour${hours > 1 ? 's' : ''}';
    }
    final days = (minutes / 1440).floor();
    return '$days day${days > 1 ? 's' : ''}';
  }

  String _formatDateForExport(String? dateStr) {
    if (dateStr == null || dateStr.isEmpty) return 'N/A';
    final date = DateTime.tryParse(dateStr);
    if (date == null) return 'Invalid';
    return DateFormat('dd/MM/yyyy HH:mm').format(date);
  }

  Future<void> _updateStatus(String ticketId, String newStatus) async {
    final response = await _tmsService.updateTicketStatus(ticketId, newStatus);

    if (response['success'] == true) {
      _showSuccessSnackbar('Status updated successfully!');

      if (newStatus == 'closed') {
        setState(() {
          _tickets.removeWhere((t) => t['_id'].toString() == ticketId);
          _applyFilters();
          _calculateStatistics();
        });
      } else {
        _fetchTickets();
      }
    } else {
      _showErrorSnackbar('Failed to update status');
    }
  }

  void _showSuccessSnackbar(String message) {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Row(
          children: [
            const Icon(Icons.check_circle, color: Colors.white),
            const SizedBox(width: 12),
            Text(message),
          ],
        ),
        backgroundColor: mediumBlue,
        behavior: SnackBarBehavior.floating,
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
        margin: const EdgeInsets.all(16),
      ),
    );
  }

  void _showErrorSnackbar(String message) {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Row(
          children: [
            const Icon(Icons.error_outline, color: Colors.white),
            const SizedBox(width: 12),
            Text(message),
          ],
        ),
        backgroundColor: const Color(0xFFEF4444),
        behavior: SnackBarBehavior.floating,
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
        margin: const EdgeInsets.all(16),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: lightBlue,
      appBar: AppBar(
        backgroundColor: darkBlue,
        elevation: 0,
        leading: IconButton(
          icon: Container(
            padding: const EdgeInsets.all(8),
            decoration: BoxDecoration(
              color: Colors.white.withOpacity(0.2),
              borderRadius: BorderRadius.circular(12),
            ),
            child: const Icon(Icons.arrow_back_ios_new, color: Colors.white, size: 18),
          ),
          onPressed: () => Navigator.pop(context),
        ),
        title: const Text(
          'My Tickets',
          style: TextStyle(
            color: Colors.white,
            fontWeight: FontWeight.bold,
            fontSize: 20,
          ),
        ),
        centerTitle: true,
        actions: [
          // Filters Button
          IconButton(
            icon: Container(
              padding: const EdgeInsets.all(8),
              decoration: BoxDecoration(
                color: Colors.white.withOpacity(0.2),
                borderRadius: BorderRadius.circular(12),
              ),
              child: const Icon(Icons.filter_list, color: Colors.white, size: 20),
            ),
            onPressed: _showFiltersDialog,
            tooltip: 'Filters',
          ),
          // Refresh Button
          IconButton(
            icon: Container(
              padding: const EdgeInsets.all(8),
              decoration: BoxDecoration(
                color: Colors.white.withOpacity(0.2),
                borderRadius: BorderRadius.circular(12),
              ),
              child: const Icon(Icons.refresh, color: Colors.white, size: 20),
            ),
            onPressed: _isLoading ? null : _fetchTickets,
            tooltip: 'Refresh',
          ),
          // Export Button
          IconButton(
            icon: _isExporting
                ? const SizedBox(
                    width: 20,
                    height: 20,
                    child: CircularProgressIndicator(
                      strokeWidth: 2,
                      valueColor: AlwaysStoppedAnimation<Color>(Colors.white),
                    ),
                  )
                : Container(
                    padding: const EdgeInsets.all(8),
                    decoration: BoxDecoration(
                      color: Colors.white.withOpacity(0.2),
                      borderRadius: BorderRadius.circular(12),
                    ),
                    child: const Icon(Icons.download, color: Colors.white, size: 20),
                  ),
            onPressed: _isExporting ? null : _exportToExcel,
            tooltip: 'Export to Excel',
          ),
          const SizedBox(width: 8),
        ],
      ),
      body: Column(
        children: [
          _buildStatisticsCards(),
          _buildSearchBar(),
          if (_priorityFilter != 'all' || _dateFrom != null || _dateTo != null)
            _buildActiveFiltersChips(),
          Expanded(
            child: _isLoading
                ? Center(child: CircularProgressIndicator(color: mediumBlue))
                : _filteredTickets.isEmpty
                    ? _buildEmptyState()
                    : _buildTicketsTable(),
          ),
        ],
      ),
    );
  }

  // ============================================================================
  // SEARCH BAR
  // ============================================================================
  Widget _buildSearchBar() {
    return Container(
      margin: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
      child: TextField(
        controller: _searchController,
        style: TextStyle(color: darkBlue),
        decoration: InputDecoration(
          hintText: 'Search tickets...',
          hintStyle: const TextStyle(color: Color(0xFF94A3B8)),
          prefixIcon: Icon(Icons.search, color: mediumBlue),
          suffixIcon: _searchQuery.isNotEmpty
              ? IconButton(
                  icon: const Icon(Icons.clear, color: Color(0xFF64748B)),
                  onPressed: () {
                    _searchController.clear();
                    setState(() {
                      _searchQuery = '';
                      _applyFilters();
                    });
                  },
                )
              : null,
          filled: true,
          fillColor: Colors.white,
          border: OutlineInputBorder(
            borderRadius: BorderRadius.circular(12),
            borderSide: BorderSide(color: accentBlue.withOpacity(0.3)),
          ),
          enabledBorder: OutlineInputBorder(
            borderRadius: BorderRadius.circular(12),
            borderSide: BorderSide(color: accentBlue.withOpacity(0.3)),
          ),
          focusedBorder: OutlineInputBorder(
            borderRadius: BorderRadius.circular(12),
            borderSide: BorderSide(color: mediumBlue, width: 2),
          ),
          contentPadding: const EdgeInsets.symmetric(vertical: 12, horizontal: 16),
        ),
        onChanged: (value) {
          setState(() {
            _searchQuery = value;
            _applyFilters();
          });
        },
      ),
    );
  }

  // ============================================================================
  // STATISTICS CARDS
  // ============================================================================
  Widget _buildStatisticsCards() {
    return Container(
      margin: const EdgeInsets.all(16),
      child: Row(
        children: [
          Expanded(
            child: _buildStatCard('Open', _openCount, Icons.radio_button_unchecked, const Color(0xFFEF4444)),
          ),
          const SizedBox(width: 12),
          Expanded(
            child: _buildStatCard('In Progress', _inProgressCount, Icons.autorenew, const Color(0xFFF59E0B)),
          ),
          const SizedBox(width: 12),
          Expanded(
            child: _buildStatCard('High Priority', _highPriorityCount, Icons.priority_high, const Color(0xFF8B5CF6)),
          ),
        ],
      ),
    );
  }

  Widget _buildStatCard(String label, int count, IconData icon, Color color) {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        gradient: LinearGradient(
          colors: [color.withOpacity(0.1), color.withOpacity(0.05)],
          begin: Alignment.topLeft,
          end: Alignment.bottomRight,
        ),
        borderRadius: BorderRadius.circular(16),
        border: Border.all(color: color.withOpacity(0.2)),
        boxShadow: [
          BoxShadow(color: color.withOpacity(0.1), blurRadius: 10, offset: const Offset(0, 4)),
        ],
      ),
      child: Column(
        children: [
          Icon(icon, color: color, size: 24),
          const SizedBox(height: 8),
          Text(
            count.toString(),
            style: TextStyle(fontSize: 24, fontWeight: FontWeight.bold, color: darkBlue),
          ),
          const SizedBox(height: 4),
          Text(
            label,
            style: const TextStyle(fontSize: 11, color: Color(0xFF64748B), fontWeight: FontWeight.w500),
            textAlign: TextAlign.center,
            maxLines: 1,
            overflow: TextOverflow.ellipsis,
          ),
        ],
      ),
    );
  }

  // ============================================================================
  // ACTIVE FILTERS CHIPS
  // ============================================================================
  Widget _buildActiveFiltersChips() {
    return Container(
      margin: const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
      child: Wrap(
        spacing: 8,
        runSpacing: 8,
        children: [
          if (_priorityFilter != 'all')
            _buildFilterChip('Priority: $_priorityFilter', () {
              setState(() {
                _priorityFilter = 'all';
                _applyFilters();
              });
            }),
          if (_dateFrom != null)
            _buildFilterChip('From: ${DateFormat('MMM dd').format(_dateFrom!)}', () {
              setState(() {
                _dateFrom = null;
                _applyFilters();
              });
            }),
          if (_dateTo != null)
            _buildFilterChip('To: ${DateFormat('MMM dd').format(_dateTo!)}', () {
              setState(() {
                _dateTo = null;
                _applyFilters();
              });
            }),
        ],
      ),
    );
  }

  Widget _buildFilterChip(String label, VoidCallback onRemove) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
      decoration: BoxDecoration(
        color: mediumBlue.withOpacity(0.1),
        borderRadius: BorderRadius.circular(20),
        border: Border.all(color: mediumBlue.withOpacity(0.3)),
      ),
      child: Row(
        mainAxisSize: MainAxisSize.min,
        children: [
          Text(
            label,
            style: TextStyle(color: mediumBlue, fontSize: 12, fontWeight: FontWeight.w600),
          ),
          const SizedBox(width: 6),
          GestureDetector(
            onTap: onRemove,
            child: Icon(Icons.close, color: mediumBlue, size: 16),
          ),
        ],
      ),
    );
  }

  // ============================================================================
  // TICKETS TABLE - WITH HORIZONTAL AND VERTICAL SCROLLING
  // ============================================================================
  Widget _buildTicketsTable() {
    return Container(
      margin: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(12),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.05),
            blurRadius: 10,
            offset: const Offset(0, 4),
          ),
        ],
      ),
      child: Column(
        children: [
          // Table Header
          Container(
            decoration: BoxDecoration(
              gradient: LinearGradient(
                colors: [darkBlue, mediumBlue],
              ),
              borderRadius: const BorderRadius.only(
                topLeft: Radius.circular(12),
                topRight: Radius.circular(12),
              ),
            ),
            child: SingleChildScrollView(
              scrollDirection: Axis.horizontal,
              child: Row(
                children: [
                  _buildHeaderCell('Ticket #', 120),
                  _buildHeaderCell('Subject', 250),
                  _buildHeaderCell('Priority', 120),
                  _buildHeaderCell('Status', 150),
                  _buildHeaderCell('Timeline', 120),
                  _buildHeaderCell('Deadline', 180),
                  _buildHeaderCell('Assigned To', 150),
                  _buildHeaderCell('Created', 150),
                  _buildHeaderCell('Actions', 120),
                ],
              ),
            ),
          ),

          // Table Body with Vertical Scrolling
          Expanded(
            child: SingleChildScrollView(
              child: SingleChildScrollView(
                scrollDirection: Axis.horizontal,
                child: Column(
                  children: _filteredTickets.map((ticket) {
                    return _buildTableRow(ticket);
                  }).toList(),
                ),
              ),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildHeaderCell(String title, double width) {
    return Container(
      width: width,
      padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 16),
      child: Text(
        title,
        style: const TextStyle(
          color: Colors.white,
          fontWeight: FontWeight.bold,
          fontSize: 14,
        ),
        textAlign: TextAlign.left,
      ),
    );
  }

  Widget _buildTableRow(Map<String, dynamic> ticket) {
    final ticketId = ticket['_id']?.toString() ?? '';
    final ticketNumber = ticket['ticket_number'] ?? 'N/A';
    final subject = ticket['subject'] ?? 'No Subject';
    final priority = ticket['priority'] ?? 'Medium';
    final status = ticket['status'] ?? 'Open';
    final timeline = ticket['timeline'];
    final deadline = ticket['deadline'];
    final createdAt = ticket['created_at'];
    final assignedToName = ticket['assigned_to_name'] ?? 'Not Assigned';

    return InkWell(
      onTap: () => _showTicketDetailsDialog(ticket),
      child: Container(
        decoration: BoxDecoration(
          border: Border(
            bottom: BorderSide(color: Colors.grey[200]!),
          ),
        ),
        child: Row(
          children: [
            _buildDataCell(
              Container(
                padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                decoration: BoxDecoration(
                  gradient: LinearGradient(colors: [darkBlue, mediumBlue]),
                  borderRadius: BorderRadius.circular(20),
                ),
                child: Text(
                  ticketNumber,
                  style: const TextStyle(
                    fontSize: 12,
                    fontWeight: FontWeight.bold,
                    color: Colors.white,
                  ),
                ),
              ),
              120,
            ),
            _buildDataCell(
              Text(
                subject,
                style: TextStyle(
                  fontSize: 14,
                  fontWeight: FontWeight.w600,
                  color: darkBlue,
                ),
                maxLines: 2,
                overflow: TextOverflow.ellipsis,
              ),
              250,
            ),
            _buildDataCell(_buildPriorityBadge(priority), 120),
            _buildDataCell(_buildStatusDropdown(ticketId, status), 150),
            _buildDataCell(_buildTimelineBadge(timeline), 120),
            _buildDataCell(_buildDeadlineStatus(deadline), 180),
            _buildDataCell(
              Text(
                assignedToName,
                style: TextStyle(
                  fontSize: 12,
                  fontWeight: FontWeight.w500,
                  color: assignedToName == 'Not Assigned' ? Colors.grey : darkBlue,
                ),
                maxLines: 1,
                overflow: TextOverflow.ellipsis,
              ),
              150,
            ),
            _buildDataCell(
              Text(
                _formatDate(createdAt),
                style: const TextStyle(fontSize: 12, color: Color(0xFF64748B)),
              ),
              150,
            ),
            _buildDataCell(
              IconButton(
                icon: Icon(Icons.visibility, size: 18, color: mediumBlue),
                onPressed: () async {
                  final updated = await Navigator.push(
                    context,
                    MaterialPageRoute(
                      builder: (_) => TicketDetailScreen(ticket: ticket),
                    ),
                  );
                  if (updated == true) _fetchTickets();
                },
                tooltip: 'View Details',
              ),
              120,
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildDataCell(Widget child, double width) {
    return Container(
      width: width,
      padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 16),
      child: child,
    );
  }

  // ============================================================================
  // BADGE WIDGETS
  // ============================================================================
  Widget _buildPriorityBadge(String priority) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 6),
      decoration: BoxDecoration(
        color: _getPriorityColor(priority).withOpacity(0.15),
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: _getPriorityColor(priority).withOpacity(0.3)),
      ),
      child: Text(
        priority.toUpperCase(),
        style: TextStyle(
          fontSize: 11,
          fontWeight: FontWeight.bold,
          color: _getPriorityColor(priority),
        ),
      ),
    );
  }

  Color _getPriorityColor(String priority) {
    switch (priority.toLowerCase()) {
      case 'high':
        return const Color(0xFFEF4444);
      case 'medium':
        return const Color(0xFFF59E0B);
      case 'low':
        return const Color(0xFF10B981);
      default:
        return Colors.grey;
    }
  }

  Widget _buildStatusDropdown(String ticketId, String currentStatus) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 8),
      decoration: BoxDecoration(
        color: _getStatusColor(currentStatus).withOpacity(0.15),
        borderRadius: BorderRadius.circular(8),
        border: Border.all(color: _getStatusColor(currentStatus).withOpacity(0.3)),
      ),
      child: DropdownButton<String>(
        value: currentStatus,
        underline: const SizedBox(),
        isDense: true,
        dropdownColor: Colors.white,
        style: TextStyle(fontSize: 12, fontWeight: FontWeight.w600, color: _getStatusColor(currentStatus)),
        items: const [
          DropdownMenuItem(value: 'Open', child: Text('Open')),
          DropdownMenuItem(value: 'In Progress', child: Text('In Progress')),
          DropdownMenuItem(value: 'closed', child: Text('Close')),
        ],
        onChanged: (newStatus) {
          if (newStatus != null && newStatus != currentStatus) {
            if (newStatus == 'closed') {
              _showCloseConfirmation(ticketId);
            } else {
              _updateStatus(ticketId, newStatus);
            }
          }
        },
      ),
    );
  }

  Color _getStatusColor(String status) {
    switch (status) {
      case 'Open':
        return const Color(0xFFEF4444);
      case 'In Progress':
        return const Color(0xFFF59E0B);
      case 'closed':
        return const Color(0xFF10B981);
      default:
        return Colors.grey;
    }
  }

  void _showCloseConfirmation(String ticketId) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        backgroundColor: Colors.white,
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),
        title: Text('Close Ticket?', style: TextStyle(color: darkBlue)),
        content: const Text(
          'Are you sure you want to close this ticket? It will be moved to the Closed Tickets section.',
          style: TextStyle(color: Color(0xFF64748B)),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Cancel'),
          ),
          ElevatedButton(
            onPressed: () {
              Navigator.pop(context);
              _updateStatus(ticketId, 'closed');
            },
            style: ElevatedButton.styleFrom(backgroundColor: const Color(0xFFEF4444)),
            child: const Text('Close Ticket'),
          ),
        ],
      ),
    );
  }

  Widget _buildTimelineBadge(int? minutes) {
    if (minutes == null || minutes <= 0) {
      return Container(
        padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 6),
        decoration: BoxDecoration(
          color: lightBlue,
          borderRadius: BorderRadius.circular(12),
          border: Border.all(color: accentBlue.withOpacity(0.3)),
        ),
        child: const Row(
          mainAxisSize: MainAxisSize.min,
          children: [
            Icon(Icons.schedule, size: 14, color: Color(0xFF94A3B8)),
            SizedBox(width: 4),
            Text('Not Set', style: TextStyle(fontSize: 11, color: Color(0xFF94A3B8))),
          ],
        ),
      );
    }

    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 6),
      decoration: BoxDecoration(
        color: mediumBlue.withOpacity(0.1),
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: mediumBlue.withOpacity(0.3)),
      ),
      child: Row(
        mainAxisSize: MainAxisSize.min,
        children: [
          Icon(Icons.timer, size: 14, color: mediumBlue),
          const SizedBox(width: 4),
          Text(
            _formatTimeline(minutes),
            style: TextStyle(fontSize: 11, fontWeight: FontWeight.w600, color: mediumBlue),
          ),
        ],
      ),
    );
  }

  String _formatTimeline(int minutes) {
    if (minutes < 60) return '$minutes min';
    if (minutes < 1440) {
      final hours = (minutes / 60).floor();
      return '$hours hour${hours > 1 ? 's' : ''}';
    }
    if (minutes < 10080) {
      final days = (minutes / 1440).floor();
      return '$days day${days > 1 ? 's' : ''}';
    }
    if (minutes < 43200) {
      final weeks = (minutes / 10080).floor();
      return '$weeks week${weeks > 1 ? 's' : ''}';
    }
    final months = (minutes / 43200).floor();
    return '$months month${months > 1 ? 's' : ''}';
  }

  Widget _buildDeadlineStatus(String? deadline) {
    if (deadline == null || deadline.isEmpty) {
      return Container(
        padding: const EdgeInsets.all(8),
        decoration: BoxDecoration(
          color: lightBlue,
          borderRadius: BorderRadius.circular(12),
          border: Border.all(color: accentBlue.withOpacity(0.3)),
        ),
        child: const Text('No deadline', style: TextStyle(fontSize: 11, color: Color(0xFF94A3B8))),
      );
    }

    final deadlineDate = DateTime.tryParse(deadline);
    if (deadlineDate == null) {
      return const Text('Invalid deadline');
    }

    final now = DateTime.now();
    final difference = deadlineDate.difference(now);

    final isOverdue = difference.isNegative;
    final isCritical = !isOverdue && difference.inHours < 1;
    final isWarning = !isOverdue && !isCritical && difference.inHours < 4;

    Color bgColor, textColor;
    IconData icon;
    String statusText;
    bool shouldPulse = false;

    if (isOverdue) {
      bgColor = const Color(0xFFEF4444).withOpacity(0.1);
      textColor = const Color(0xFFEF4444);
      icon = Icons.warning;
      final hours = difference.abs().inHours;
      final days = difference.abs().inDays;
      statusText = days > 0 ? 'Overdue by $days day${days > 1 ? 's' : ''}' : 'Overdue by $hours hr${hours > 1 ? 's' : ''}';
      shouldPulse = true;
    } else if (isCritical) {
      bgColor = const Color(0xFFFB923C).withOpacity(0.1);
      textColor = const Color(0xFFFB923C);
      icon = Icons.hourglass_bottom;
      statusText = '${difference.inMinutes} min left';
      shouldPulse = true;
    } else if (isWarning) {
      bgColor = const Color(0xFFF59E0B).withOpacity(0.1);
      textColor = const Color(0xFFF59E0B);
      icon = Icons.hourglass_empty;
      statusText = '${difference.inHours} hr${difference.inHours > 1 ? 's' : ''} left';
    } else {
      bgColor = const Color(0xFF10B981).withOpacity(0.1);
      textColor = const Color(0xFF10B981);
      icon = Icons.check_circle;
      final days = difference.inDays;
      statusText = days > 0 ? '$days day${days > 1 ? 's' : ''} left' : '${difference.inHours} hrs left';
    }

    final content = Container(
      padding: const EdgeInsets.all(8),
      decoration: BoxDecoration(
        color: bgColor,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: textColor.withOpacity(0.3)),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        mainAxisSize: MainAxisSize.min,
        children: [
          Row(
            mainAxisSize: MainAxisSize.min,
            children: [
              Icon(icon, size: 12, color: textColor),
              const SizedBox(width: 4),
              Flexible(
                child: Text(
                  statusText,
                  style: TextStyle(fontSize: 10, fontWeight: FontWeight.bold, color: textColor),
                ),
              ),
            ],
          ),
          const SizedBox(height: 2),
          Text(
            DateFormat('MMM dd, hh:mm a').format(deadlineDate),
            style: TextStyle(fontSize: 9, color: textColor.withOpacity(0.8)),
          ),
        ],
      ),
    );

    if (shouldPulse) {
      return FadeTransition(opacity: _pulseAnimation, child: content);
    }

    return content;
  }

  String _formatDate(String? dateStr) {
    if (dateStr == null || dateStr.isEmpty) return 'N/A';

    final date = DateTime.tryParse(dateStr);
    if (date == null) return 'Invalid';

    return DateFormat('MMM dd, yyyy').format(date);
  }

