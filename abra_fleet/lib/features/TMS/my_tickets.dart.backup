          Icon(Icons.inbox, size: 80, color: accentBlue.withOpacity(0.4)),
          const SizedBox(height: 16),
          const Text(
            'No tickets found',
            style: TextStyle(
              fontSize: 18,
              fontWeight: FontWeight.w600,
              color: Color(0xFF64748B),
            ),
          ),
          const SizedBox(height: 8),
          Text(
            _searchQuery.isNotEmpty ? 'Try adjusting your search' : 'You have no active tickets',
            style: const TextStyle(fontSize: 14, color: Color(0xFF94A3B8)),
          ),
        ],
      ),
    );
  }

