  Widget _buildStatusFilterButtons() {
    return Wrap(
      spacing: 8,
      children: [
        _buildFilterButton('Active', _statusFilter == 'active', () {
          setState(() => _statusFilter = 'active');
        }),
        _buildFilterButton('Open', _statusFilter == 'Open', () {
          setState(() => _statusFilter = 'Open');
        }),
        _buildFilterButton('In Progress', _statusFilter == 'In Progress', () {
          setState(() => _statusFilter = 'In Progress');
        }),
        _buildFilterButton('All', _statusFilter == 'all', () {
          setState(() => _statusFilter = 'all');
        }),
      ],
    );
  }

  Widget _buildPriorityFilterButtons() {
    return Wrap(
      spacing: 8,
      children: [
        _buildFilterButton('All', _priorityFilter == 'all', () {
          setState(() => _priorityFilter = 'all');
        }),
        _buildFilterButton('High', _priorityFilter == 'High', () {
          setState(() => _priorityFilter = 'High');
        }),
        _buildFilterButton('Medium', _priorityFilter == 'Medium', () {
          setState(() => _priorityFilter = 'Medium');
        }),
        _buildFilterButton('Low', _priorityFilter == 'Low', () {
          setState(() => _priorityFilter = 'Low');
        }),
      ],
    );
  }

  Widget _buildFilterButton(String label, bool isSelected, VoidCallback onTap) {
    return GestureDetector(
      onTap: onTap,
      child: Container(
        padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
        decoration: BoxDecoration(
          color: isSelected ? mediumBlue : lightBlue,
          borderRadius: BorderRadius.circular(20),
          border: Border.all(color: isSelected ? mediumBlue : accentBlue.withOpacity(0.3)),
        ),
        child: Text(
          label,
          style: TextStyle(
            color: isSelected ? Colors.white : const Color(0xFF64748B),
            fontWeight: isSelected ? FontWeight.w600 : FontWeight.normal,
            fontSize: 13,
          ),
        ),
      ),
    );
  }

  Widget _buildDateButton(String label, DateTime? date, Function(DateTime?) onDateSelected) {
    return GestureDetector(
      onTap: () async {
        final picked = await showDatePicker(
          context: context,
          initialDate: date ?? DateTime.now(),
          firstDate: DateTime(2020),
          lastDate: DateTime.now().add(const Duration(days: 365)),
        );
        if (picked != null) {
          onDateSelected(picked);
        }
      },
      child: Container(
        padding: const EdgeInsets.all(12),
        decoration: BoxDecoration(
          color: lightBlue,
          borderRadius: BorderRadius.circular(12),
          border: Border.all(color: accentBlue.withOpacity(0.3)),
        ),
        child: Row(
          mainAxisAlignment: MainAxisAlignment.spaceBetween,
          children: [
            Text(
              date == null ? label : DateFormat('MMM dd').format(date),
              style: TextStyle(
                color: date == null ? const Color(0xFF94A3B8) : darkBlue,
                fontSize: 13,
              ),
            ),
            const Icon(Icons.calendar_today, color: Color(0xFF64748B), size: 16),
          ],
        ),
      ),
    );
  }

  // ============================================================================
  // TICKET DETAILS DIALOG - Show as Overlay
  // ============================================================================
  void _showTicketDetailsDialog(Map<String, dynamic> ticket) {
    showDialog(
      context: context,
      builder: (context) => Dialog(
        backgroundColor: Colors.transparent,
        insetPadding: const EdgeInsets.all(20),
        child: Container(
          constraints: const BoxConstraints(maxWidth: 800, maxHeight: 700),
          decoration: BoxDecoration(
            color: Colors.white,
            borderRadius: BorderRadius.circular(20),
            boxShadow: [
              BoxShadow(
                color: Colors.black.withOpacity(0.2),
                blurRadius: 20,
                offset: const Offset(0, 10),
              ),
            ],
          ),
          child: Column(
            children: [
              // Header
              Container(
                padding: const EdgeInsets.all(20),
                decoration: BoxDecoration(
                  gradient: LinearGradient(colors: [darkBlue, mediumBlue]),
                  borderRadius: const BorderRadius.only(
                    topLeft: Radius.circular(20),
                    topRight: Radius.circular(20),
                  ),
                ),
                child: Row(
                  children: [
                    Container(
                      padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                      decoration: BoxDecoration(
                        color: Colors.white.withOpacity(0.2),
                        borderRadius: BorderRadius.circular(20),
                      ),
                      child: Text(
                        ticket['ticket_number'] ?? 'N/A',
                        style: const TextStyle(
                          fontSize: 14,
                          fontWeight: FontWeight.bold,
                          color: Colors.white,
                        ),
                      ),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: Text(
                        'Ticket Details',
                        style: const TextStyle(
                          fontSize: 18,
                          fontWeight: FontWeight.bold,
                          color: Colors.white,
                        ),
                      ),
                    ),
                    IconButton(
                      icon: const Icon(Icons.close, color: Colors.white),
                      onPressed: () => Navigator.pop(context),
                    ),
                  ],
                ),
              ),

              // Content
              Expanded(
                child: SingleChildScrollView(
                  padding: const EdgeInsets.all(24),
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      // Important Dates Section
                      _buildDialogSection(
                        'Important Dates',
                        Icons.calendar_today,
                        Column(
                          children: [
                            _buildDialogInfoRow(
                              'Created',
                              _formatDate(ticket['created_at']),
                              Icons.add_circle_outline,
                              const Color(0xFF10B981),
                            ),
                            const SizedBox(height: 12),
                            _buildDialogInfoRow(
                              'Deadline',
                              ticket['deadline'] != null
                                  ? DateFormat('MMM dd, yyyy hh:mm a')
                                      .format(DateTime.parse(ticket['deadline']))
                                  : 'No deadline',
                              Icons.alarm,
                              const Color(0xFFEF4444),
                            ),
                          ],
                        ),
                      ),

                      const SizedBox(height: 24),

                      // Assigned To Section
                      _buildDialogSection(
                        'Assigned To',
                        Icons.person,
                        Container(
                          padding: const EdgeInsets.all(16),
                          decoration: BoxDecoration(
                            color: mediumBlue.withOpacity(0.1),
                            borderRadius: BorderRadius.circular(12),
                            border: Border.all(color: mediumBlue.withOpacity(0.3)),
                          ),
                          child: Row(
                            children: [
                              CircleAvatar(
                                backgroundColor: mediumBlue,
                                child: Text(
                                  (ticket['assigned_to_name'] ?? 'N')
                                      .substring(0, 1)
                                      .toUpperCase(),
                                  style: const TextStyle(
                                    color: Colors.white,
                                    fontWeight: FontWeight.bold,
                                  ),
                                ),
                              ),
                              const SizedBox(width: 12),
                              Expanded(
                                child: Text(
                                  ticket['assigned_to_name'] ?? 'Not Assigned',
                                  style: TextStyle(
                                    fontSize: 16,
                                    fontWeight: FontWeight.w600,
                                    color: darkBlue,
                                  ),
                                ),
                              ),
                            ],
                          ),
                        ),
                      ),

                      const SizedBox(height: 24),

                      // Update Status Section
                      _buildDialogSection(
                        'Update Status',
                        Icons.update,
                        Column(
                          children: [
                            _buildStatusButton(
                              'Open',
                              ticket['status'] == 'Open',
                              const Color(0xFFEF4444),
                              () {
                                if (ticket['status'] != 'Open') {
                                  _updateStatus(ticket['_id'].toString(), 'Open');
                                  Navigator.pop(context);
                                }
                              },
                            ),
                            const SizedBox(height: 12),
                            _buildStatusButton(
                              'In Progress',
                              ticket['status'] == 'In Progress',
                              const Color(0xFFF59E0B),
                              () {
                                if (ticket['status'] != 'In Progress') {
                                  _updateStatus(ticket['_id'].toString(), 'In Progress');
                                  Navigator.pop(context);
                                }
                              },
                            ),
                            const SizedBox(height: 12),
                            _buildStatusButton(
                              'Close Ticket',
                              ticket['status'] == 'closed',
                              const Color(0xFF10B981),
                              () {
                                Navigator.pop(context);
                                _showCloseConfirmation(ticket['_id'].toString());
                              },
                            ),
                          ],
                        ),
                      ),
                    ],
                  ),
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }

  Widget _buildDialogSection(String title, IconData icon, Widget content) {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Row(
          children: [
            Container(
              padding: const EdgeInsets.all(8),
              decoration: BoxDecoration(
                color: mediumBlue.withOpacity(0.1),
                borderRadius: BorderRadius.circular(8),
              ),
              child: Icon(icon, color: mediumBlue, size: 20),
            ),
            const SizedBox(width: 12),
            Text(
              title,
              style: TextStyle(
                fontSize: 16,
                fontWeight: FontWeight.bold,
                color: darkBlue,
              ),
            ),
          ],
        ),
        const SizedBox(height: 16),
        content,
      ],
    );
  }

