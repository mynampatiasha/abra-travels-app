        // Setup unread count listener
        _setupUnreadCountListener();
      }
    });
  }

  void _setupUnreadCountListener() {
    final currentUser = FirebaseAuth.instance.currentUser;
    if (currentUser == null) {
      debugPrint('❌ CLIENT SHELL: No current user for unread count');
      return;
    }

    debugPrint('🔔 CLIENT SHELL: Setting up unread count listener for ${currentUser.uid}');
    final notificationsRef = FirebaseDatabase.instance.ref('notifications/${currentUser.uid}');
    
    notificationsRef.onValue.listen((event) {
      debugPrint('📊 CLIENT SHELL: Unread count data received');
      
      if (!event.snapshot.exists) {
        debugPrint('📊 CLIENT SHELL: No notifications - count = 0');
        setState(() => _notificationCount = 0);
        return;
      }

      final data = event.snapshot.value as Map<dynamic, dynamic>?;
      if (data == null) {
        debugPrint('📊 CLIENT SHELL: Notification data is null - count = 0');
        setState(() => _notificationCount = 0);
        return;
      }

      int unreadCount = 0;
      data.forEach((key, value) {
        if (value['isRead'] != true) {
          unreadCount++;
        }
      });

      debugPrint('📊 CLIENT SHELL: Total notifications: ${data.length}, Unread: $unreadCount');
      setState(() => _notificationCount = unreadCount);
    });
  }

  @override
  void dispose() {
    _notificationService.dispose();
    super.dispose();
  }

