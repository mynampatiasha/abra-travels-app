              ),
              child: Column(
                children: [
                  Text(
                    'Trip Trends (7 Days)',
                    style: TextStyle(
                      color: Colors.white.withOpacity(0.9),
                      fontSize: 14,
                      fontWeight: FontWeight.w600,
