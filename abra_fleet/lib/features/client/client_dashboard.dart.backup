                      ),
                    ),
                  ],
                ),
                const SizedBox(height: 16),
                Text(
                  'Get real-time insights into your fleet operations with interactive charts, live data tracking, and comprehensive analytics. Monitor employee transportation, track SOS alerts, and optimize your fleet performance.',
                  style: TextStyle(
                    fontSize: 16,
                    color: Colors.white.withOpacity(0.9),
                    height: 1.6,
                  ),
                ),
                const SizedBox(height: 20),
                Row(
                  children: [
                    _buildQuickStat('${_employees.length}', 'Employees', Icons.people),
                    const SizedBox(width: 24),
                    _buildQuickStat('${_activeTrips.length}', 'Active Trips', Icons.directions_car),
                    const SizedBox(width: 24),
                    _buildQuickStat('${_activeSOS.length}', 'SOS Alerts', Icons.warning),
                  ],
                ),
              ],
            ),
          ),
          
          // Right side - Mini chart preview
          Expanded(
            flex: 1,
            child: Container(
              height: 200,
              padding: const EdgeInsets.all(20),
              decoration: BoxDecoration(
                color: Colors.white.withOpacity(0.1),
