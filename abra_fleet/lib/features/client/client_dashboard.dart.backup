  Widget _buildQuickStat(String value, String label, IconData icon) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
      decoration: BoxDecoration(
        color: Colors.white.withOpacity(0.15),
        borderRadius: BorderRadius.circular(12),
        border: Border.all(
          color: Colors.white.withOpacity(0.2),
          width: 1,
        ),
      ),
      child: Row(
        mainAxisSize: MainAxisSize.min,
        children: [
          Icon(icon, color: Colors.white, size: 20),
          const SizedBox(width: 8),
          Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Text(
                value,
                style: const TextStyle(
                  color: Colors.white,
                  fontSize: 18,
                  fontWeight: FontWeight.bold,
                ),
              ),
              Text(
                label,
                style: TextStyle(
                  color: Colors.white.withOpacity(0.8),
                  fontSize: 12,
                ),
              ),
            ],
          ),
        ],
      ),
    );
  }

  Widget _buildEnhancedStatsGrid() {
    final stats = [
      EnhancedStatCard(
        icon: Icons.people_alt_rounded,
        iconColor: const Color(0xFF2563EB),
        iconBg: const Color(0xFF2563EB).withOpacity(0.1),
        value: '${_employees.length}',
        label: 'Total Employees',
        change: '+${(_employees.length * 0.12).round()}',
        changePositive: true,
        trend: _generateMiniTrend(5),
      ),
      EnhancedStatCard(
        icon: Icons.directions_car_rounded,
        iconColor: const Color(0xFF10B981),
        iconBg: const Color(0xFF10B981).withOpacity(0.1),
        value: '${_activeTrips.length}',
        label: 'Active Trips',
        change: 'Live',
        changePositive: true,
        trend: _generateMiniTrend(3),
      ),
      EnhancedStatCard(
        icon: Icons.check_circle_rounded,
        iconColor: const Color(0xFF059669),
        iconBg: const Color(0xFF059669).withOpacity(0.1),
        value: '${_completedTrips.length}',
        label: 'Completed Today',
        change: '+${(_completedTrips.length * 0.08).round()}',
        changePositive: true,
        trend: _generateMiniTrend(4),
      ),
      EnhancedStatCard(
        icon: Icons.schedule_rounded,
        iconColor: const Color(0xFFF59E0B),
        iconBg: const Color(0xFFF59E0B).withOpacity(0.1),
        value: '${_pendingRosters.length}',
        label: 'Pending Rosters',
        change: _pendingRosters.length > 10 ? 'High' : 'Normal',
        changePositive: _pendingRosters.length <= 10,
        trend: _generateMiniTrend(2),
      ),
      EnhancedStatCard(
        icon: Icons.warning_amber_rounded,
        iconColor: _activeSOS.isEmpty ? const Color(0xFF10B981) : const Color(0xFFEF4444),
        iconBg: (_activeSOS.isEmpty ? const Color(0xFF10B981) : const Color(0xFFEF4444)).withOpacity(0.1),
        value: '${_activeSOS.length}',
        label: 'Active SOS Alerts',
        change: _activeSOS.isEmpty ? 'All Clear' : 'Attention',
        changePositive: _activeSOS.isEmpty,
        trend: _generateMiniTrend(1),
      ),
      EnhancedStatCard(
        icon: Icons.analytics_rounded,
        iconColor: const Color(0xFF8B5CF6),
        iconBg: const Color(0xFF8B5CF6).withOpacity(0.1),
        value: '94.5%',
        label: 'On-Time Performance',
        change: '+2.3%',
        changePositive: true,
        trend: _generateMiniTrend(6),
      ),
    ];

    return GridView.builder(
      shrinkWrap: true,
      physics: const NeverScrollableScrollPhysics(),
      gridDelegate: const SliverGridDelegateWithFixedCrossAxisCount(
        crossAxisCount: 3,
        crossAxisSpacing: 20,
        mainAxisSpacing: 20,
        childAspectRatio: 2.2,
      ),
      itemCount: stats.length,
      itemBuilder: (context, index) => _buildEnhancedStatCard(stats[index]),
    );
  }

  List<FlSpot> _generateMiniTrend(int seed) {
    final random = seed * 7;
    return List.generate(7, (index) {
      return FlSpot(index.toDouble(), (random + index * 2 + (index % 3)).toDouble());
    });
  }

  Widget _buildEnhancedStatCard(EnhancedStatCard stat) {
    return Container(
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(16),
        border: Border.all(
          color: Colors.black.withOpacity(0.05),
        ),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.08),
            blurRadius: 12,
            offset: const Offset(0, 4),
          ),
        ],
      ),
      child: Material(
        color: Colors.transparent,
        child: InkWell(
          onTap: () {},
          borderRadius: BorderRadius.circular(16),
          child: Padding(
            padding: const EdgeInsets.all(20),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                // Header row with icon and trend
                Row(
                  children: [
                    Container(
                      width: 48,
                      height: 48,
                      decoration: BoxDecoration(
                        color: stat.iconBg,
                        borderRadius: BorderRadius.circular(12),
                      ),
                      child: Icon(
                        stat.icon,
                        color: stat.iconColor,
                        size: 24,
                      ),
                    ),
                    const Spacer(),
                    // Mini trend chart
                    SizedBox(
                      width: 60,
                      height: 30,
                      child: LineChart(
                        LineChartData(
                          gridData: const FlGridData(show: false),
                          titlesData: const FlTitlesData(show: false),
                          borderData: FlBorderData(show: false),
                          lineBarsData: [
                            LineChartBarData(
                              spots: stat.trend,
                              isCurved: true,
                              color: stat.iconColor,
                              barWidth: 2,
                              dotData: const FlDotData(show: false),
                            ),
                          ],
                        ),
                      ),
                    ),
                  ],
                ),
                const SizedBox(height: 16),
                
                // Value and label
                Text(
                  stat.value,
                  style: const TextStyle(
                    fontSize: 28,
                    fontWeight: FontWeight.bold,
                    color: Color(0xFF1E293B),
                  ),
                ),
                const SizedBox(height: 4),
                Text(
                  stat.label,
                  style: const TextStyle(
                    fontSize: 14,
                    fontWeight: FontWeight.w500,
                    color: Color(0xFF64748B),
                  ),
                  maxLines: 1,
                  overflow: TextOverflow.ellipsis,
                ),
                const SizedBox(height: 8),
                
                // Change indicator
                Row(
                  children: [
                    Icon(
                      stat.changePositive
                          ? Icons.trending_up
                          : Icons.trending_down,
                      size: 14,
                      color: stat.changePositive
                          ? const Color(0xFF10B981)
                          : const Color(0xFFEF4444),
                    ),
                    const SizedBox(width: 4),
                    Text(
                      stat.change,
                      style: TextStyle(
                        fontSize: 12,
                        fontWeight: FontWeight.w600,
                        color: stat.changePositive
                            ? const Color(0xFF10B981)
                            : const Color(0xFFEF4444),
                      ),
                    ),
                  ],
                ),
              ],
            ),
          ),
        ),
      ),
    );
  }

  Widget _buildQuickActions() {
    return Container(
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(
          color: Colors.black.withOpacity(0.05),
        ),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.04),
            blurRadius: 8,
            offset: const Offset(0, 2),
          ),
        ],
      ),
      child: Padding(
        padding: const EdgeInsets.all(24),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const Text(
              'Quick Actions',
              style: TextStyle(
                fontSize: 18,
                fontWeight: FontWeight.bold,
                color: Color(0xFF1e293b),
              ),
            ),
            const SizedBox(height: 20),
            _buildActionButton(
              'Create Roster',
              Icons.calendar_today,
              const Color(0xFF2563EB),
              () => _showCreateRosterDialog(),
            ),
            const SizedBox(height: 12),
            _buildActionButton(
              'Add Employee',
              Icons.person_add,
              const Color(0xFF10B981),
              () => _showAddEmployeeDialog(),
            ),
            const SizedBox(height: 12),
            _buildActionButton(
              'Export Report',
              Icons.download,
              const Color(0xFFF59E0B),
              () {
                ScaffoldMessenger.of(context).showSnackBar(
                  const SnackBar(content: Text('Exporting report...')),
                );
              },
            ),
            const SizedBox(height: 12),
            _buildActionButton(
              'Leave Requests',
              Icons.beach_access,
              const Color(0xFFF59E0B),
              () {
                // Navigate to leave requests (index 3 in the main shell)
                // This would need to be implemented with proper navigation
                ScaffoldMessenger.of(context).showSnackBar(
                  const SnackBar(content: Text('Opening leave requests...')),
                );
              },
            ),
            const SizedBox(height: 12),
            _buildActionButton(
              'Track Fleet',
              Icons.location_on,
              const Color(0xFF06b6d4),
              () {
                ScaffoldMessenger.of(context).showSnackBar(
                  const SnackBar(content: Text('Opening fleet tracker...')),
                );
              },
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildActionButton(
    String label,
    IconData icon,
    Color color,
    VoidCallback onPressed,
  ) {
    return SizedBox(
      width: double.infinity,
      child: ElevatedButton(
        onPressed: onPressed,
        style: ElevatedButton.styleFrom(
          backgroundColor: color,
          elevation: 0,
          padding: const EdgeInsets.symmetric(vertical: 16),
          shape: RoundedRectangleBorder(
            borderRadius: BorderRadius.circular(8),
          ),
        ),
        child: Row(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Icon(icon, size: 20),
            const SizedBox(width: 8),
            Text(
              label,
              style: const TextStyle(
                fontSize: 14,
                fontWeight: FontWeight.w600,
                color: Colors.white,
              ),
            ),
          ],
        ),
      ),
    );
  }

  void _showCreateRosterDialog() {
    final formKey = GlobalKey<FormState>();
    String? selectedShift;
    DateTime? startDate;
    DateTime? endDate;
    String? selectedDriver;
    String? selectedVehicle;
    String? selectedRecurrence;
    final rosterNameController = TextEditingController();
    final routesController = TextEditingController();
    final employeesController = TextEditingController();

    showDialog(
      context: context,
      builder: (BuildContext dialogContext) => StatefulBuilder(
        builder: (context, setDialogState) => AlertDialog(
          title: const Text(
            'Create Roster',
            style: TextStyle(fontWeight: FontWeight.bold),
          ),
          content: SingleChildScrollView(
            child: Form(
              key: formKey,
              child: SizedBox(
                width: MediaQuery.of(context).size.width * 0.5,
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    // Roster Name
                    TextFormField(
                      controller: rosterNameController,
                      decoration: const InputDecoration(
                        labelText: 'Roster Name *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.event_note),
                        hintText: 'e.g., Morning Shift - Oct 2025',
                      ),
                      validator: (value) {
                        if (value == null || value.isEmpty) {
                          return 'Please enter roster name';
                        }
                        return null;
                      },
                    ),
                    const SizedBox(height: 16),
                    
                    // Shift Selection
                    DropdownButtonFormField<String>(
                      decoration: const InputDecoration(
                        labelText: 'Shift *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.schedule),
                      ),
                      value: selectedShift,
                      items: const [
                        DropdownMenuItem(value: 'Morning (6 AM - 2 PM)', child: Text('Morning (6 AM - 2 PM)')),
                        DropdownMenuItem(value: 'Day (9 AM - 6 PM)', child: Text('Day (9 AM - 6 PM)')),
                        DropdownMenuItem(value: 'Evening (2 PM - 10 PM)', child: Text('Evening (2 PM - 10 PM)')),
                        DropdownMenuItem(value: 'Night (10 PM - 6 AM)', child: Text('Night (10 PM - 6 AM)')),
                      ],
                      onChanged: (value) {
                        setDialogState(() {
                          selectedShift = value;
                        });
                      },
                      validator: (value) => value == null ? 'Please select a shift' : null,
                    ),
                    const SizedBox(height: 16),
                    
                    // Start Date
                    InkWell(
                      onTap: () async {
                        final date = await showDatePicker(
                          context: context,
                          initialDate: DateTime.now(),
                          firstDate: DateTime.now(),
                          lastDate: DateTime.now().add(const Duration(days: 365)),
                        );
                        if (date != null) {
                          setDialogState(() {
                            startDate = date;
                          });
                        }
                      },
                      child: InputDecorator(
                        decoration: const InputDecoration(
                          labelText: 'Start Date *',
                          border: OutlineInputBorder(),
                          prefixIcon: Icon(Icons.calendar_today),
                        ),
                        child: Text(
                          startDate == null 
                              ? 'Select start date' 
                              : '${startDate!.day}/${startDate!.month}/${startDate!.year}',
                          style: TextStyle(
                            color: startDate == null ? Colors.grey : Colors.black,
                          ),
                        ),
                      ),
                    ),
                    const SizedBox(height: 16),
                    
                    // End Date
                    InkWell(
                      onTap: () async {
                        final date = await showDatePicker(
                          context: context,
                          initialDate: startDate ?? DateTime.now(),
                          firstDate: startDate ?? DateTime.now(),
                          lastDate: DateTime.now().add(const Duration(days: 365)),
                        );
                        if (date != null) {
                          setDialogState(() {
                            endDate = date;
                          });
                        }
                      },
                      child: InputDecorator(
                        decoration: const InputDecoration(
                          labelText: 'End Date *',
                          border: OutlineInputBorder(),
                          prefixIcon: Icon(Icons.calendar_today),
                        ),
                        child: Text(
                          endDate == null 
                              ? 'Select end date' 
                              : '${endDate!.day}/${endDate!.month}/${endDate!.year}',
                          style: TextStyle(
                            color: endDate == null ? Colors.grey : Colors.black,
                          ),
                        ),
                      ),
                    ),
                    const SizedBox(height: 16),
                    
                    // Route Selection
                    TextFormField(
                      controller: routesController,
                      decoration: const InputDecoration(
                        labelText: 'Select Routes *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.route),
                        hintText: 'e.g., Hitech-Campus, Madhapur-Campus',
                      ),
                      validator: (value) {
                        if (value == null || value.isEmpty) {
                          return 'Please enter routes';
                        }
                        return null;
                      },
                    ),
                    const SizedBox(height: 16),
                    
                    // Employee Selection
                    TextFormField(
                      controller: employeesController,
                      decoration: const InputDecoration(
                        labelText: 'Assign Employees *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.people),
                        hintText: 'Search and select employees',
                      ),
                      validator: (value) {
                        if (value == null || value.isEmpty) {
                          return 'Please assign employees';
                        }
                        return null;
                      },
                    ),
                    const SizedBox(height: 16),
                    
                    // Driver Assignment
                    DropdownButtonFormField<String>(
                      decoration: const InputDecoration(
                        labelText: 'Assign Driver *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.person),
                      ),
                      value: selectedDriver,
                      items: const [
                        DropdownMenuItem(value: 'Suresh K.', child: Text('Suresh K.')),
                        DropdownMenuItem(value: 'Ramesh M.', child: Text('Ramesh M.')),
                        DropdownMenuItem(value: 'Vijay R.', child: Text('Vijay R.')),
                        DropdownMenuItem(value: 'Kumar S.', child: Text('Kumar S.')),
                      ],
                      onChanged: (value) {
                        setDialogState(() {
                          selectedDriver = value;
                        });
                      },
                      validator: (value) => value == null ? 'Please assign a driver' : null,
                    ),
                    const SizedBox(height: 16),
                    
                    // Vehicle Assignment
                    DropdownButtonFormField<String>(
                      decoration: const InputDecoration(
                        labelText: 'Assign Vehicle *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.directions_bus),
                      ),
                      value: selectedVehicle,
                      items: const [
                        DropdownMenuItem(value: 'TS-09-EA-1234', child: Text('TS-09-EA-1234')),
                        DropdownMenuItem(value: 'TS-09-EB-5678', child: Text('TS-09-EB-5678')),
                        DropdownMenuItem(value: 'TS-09-EC-9012', child: Text('TS-09-EC-9012')),
                        DropdownMenuItem(value: 'TS-09-ED-3456', child: Text('TS-09-ED-3456')),
                      ],
                      onChanged: (value) {
                        setDialogState(() {
                          selectedVehicle = value;
                        });
                      },
                      validator: (value) => value == null ? 'Please assign a vehicle' : null,
                    ),
                    const SizedBox(height: 16),
                    
                    // Recurrence
                    DropdownButtonFormField<String>(
                      decoration: const InputDecoration(
                        labelText: 'Recurrence',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.repeat),
                      ),
                      value: selectedRecurrence,
                      items: const [
                        DropdownMenuItem(value: 'Daily', child: Text('Daily')),
                        DropdownMenuItem(value: 'Weekdays', child: Text('Weekdays (Mon-Fri)')),
                        DropdownMenuItem(value: 'Weekends', child: Text('Weekends (Sat-Sun)')),
                        DropdownMenuItem(value: 'Custom', child: Text('Custom')),
                      ],
                      onChanged: (value) {
                        setDialogState(() {
                          selectedRecurrence = value;
                        });
                      },
                    ),
                  ],
                ),
              ),
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.pop(context),
              child: const Text('Cancel'),
            ),
            ElevatedButton(
              onPressed: () {
                if (formKey.currentState!.validate() && 
                    startDate != null && 
                    endDate != null) {
                  // Add roster creation logic here
                  Navigator.pop(context);
                  ScaffoldMessenger.of(this.context).showSnackBar(
                    const SnackBar(
                      content: Text('Roster created successfully!'),
                      backgroundColor: Color(0xFF10b981),
                    ),
                  );
                } else {
                  if (startDate == null || endDate == null) {
                    ScaffoldMessenger.of(this.context).showSnackBar(
                      const SnackBar(
                        content: Text('Please select start and end dates'),
                        backgroundColor: Color(0xFFEF4444),
                      ),
                    );
                  }
                }
              },
              style: ElevatedButton.styleFrom(
                backgroundColor: const Color(0xFF2563EB),
                padding: const EdgeInsets.symmetric(horizontal: 24, vertical: 12),
              ),
              child: const Text('Create Roster'),
            ),
          ],
        ),
      ),
    );
  }

  void _showAddEmployeeDialog() {
    final formKey = GlobalKey<FormState>();
    String? selectedDepartment;
    String? selectedShift;
    String? selectedBloodGroup;
    final employeeIdController = TextEditingController();
    final nameController = TextEditingController();
    final emailController = TextEditingController();
    final phoneController = TextEditingController();
    final addressController = TextEditingController();
    final pickupController = TextEditingController();
    final emergencyController = TextEditingController();

    showDialog(
      context: context,
      builder: (BuildContext dialogContext) => StatefulBuilder(
        builder: (context, setDialogState) => AlertDialog(
          title: const Text(
            'Add Employee',
            style: TextStyle(fontWeight: FontWeight.bold),
          ),
          content: SingleChildScrollView(
            child: Form(
              key: formKey,
              child: SizedBox(
                width: MediaQuery.of(context).size.width * 0.5,
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  children: [
                    // Employee ID
                    TextFormField(
                      controller: employeeIdController,
                      decoration: const InputDecoration(
                        labelText: 'Employee ID *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.badge),
                        hintText: 'e.g., EMP-2025-001',
                      ),
                      validator: (value) {
                        if (value == null || value.isEmpty) {
                          return 'Please enter employee ID';
                        }
                        return null;
                      },
                    ),
                    const SizedBox(height: 16),
                    
                    // Full Name
                    TextFormField(
                      controller: nameController,
                      decoration: const InputDecoration(
                        labelText: 'Full Name *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.person),
                        hintText: 'e.g., John Doe',
                      ),
                      validator: (value) {
                        if (value == null || value.isEmpty) {
                          return 'Please enter full name';
                        }
                        return null;
                      },
                    ),
                    const SizedBox(height: 16),
                    
                    // Email
                    TextFormField(
                      controller: emailController,
                      decoration: const InputDecoration(
                        labelText: 'Email *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.email),
                        hintText: 'e.g., john.doe@company.com',
                      ),
                      keyboardType: TextInputType.emailAddress,
                      validator: (value) {
                        if (value == null || value.isEmpty) {
                          return 'Please enter email';
                        }
                        if (!value.contains('@')) {
                          return 'Please enter valid email';
                        }
                        return null;
                      },
                    ),
                    const SizedBox(height: 16),
                    
                    // Phone Number
                    TextFormField(
                      controller: phoneController,
                      decoration: const InputDecoration(
                        labelText: 'Phone Number *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.phone),
                        prefixText: '+91 ',
                        hintText: '9876543210',
                      ),
                      keyboardType: TextInputType.phone,
                      maxLength: 10,
                      validator: (value) {
                        if (value == null || value.isEmpty) {
                          return 'Please enter phone number';
                        }
                        if (value.length != 10) {
                          return 'Please enter valid 10-digit number';
                        }
                        return null;
                      },
                    ),
                    const SizedBox(height: 16),
                    
                    // Department
                    DropdownButtonFormField<String>(
                      decoration: const InputDecoration(
                        labelText: 'Department *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.business),
                      ),
                      value: selectedDepartment,
                      items: const [
                        DropdownMenuItem(value: 'Engineering', child: Text('Engineering')),
                        DropdownMenuItem(value: 'Sales', child: Text('Sales')),
                        DropdownMenuItem(value: 'Marketing', child: Text('Marketing')),
                        DropdownMenuItem(value: 'HR', child: Text('HR')),
                        DropdownMenuItem(value: 'Finance', child: Text('Finance')),
                        DropdownMenuItem(value: 'Operations', child: Text('Operations')),
                      ],
                      onChanged: (value) {
                        setDialogState(() {
                          selectedDepartment = value;
                        });
                      },
                      validator: (value) => value == null ? 'Please select department' : null,
                    ),
                    const SizedBox(height: 16),
                    
                    // Home Address
                    TextFormField(
                      controller: addressController,
                      decoration: const InputDecoration(
                        labelText: 'Home Address *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.home),
                        hintText: 'Enter full address',
                      ),
                      maxLines: 2,
                      validator: (value) {
                        if (value == null || value.isEmpty) {
                          return 'Please enter home address';
                        }
                        return null;
                      },
                    ),
                    const SizedBox(height: 16),
                    
                    // Pickup Location
                    TextFormField(
                      controller: pickupController,
                      decoration: const InputDecoration(
                        labelText: 'Preferred Pickup Location *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.location_on),
                        hintText: 'e.g., Hitech City, Madhapur',
                      ),
                      validator: (value) {
                        if (value == null || value.isEmpty) {
                          return 'Please enter pickup location';
                        }
                        return null;
                      },
                    ),
                    const SizedBox(height: 16),
                    
                    // Shift Timing
                    DropdownButtonFormField<String>(
                      decoration: const InputDecoration(
                        labelText: 'Shift Timing *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.access_time),
                      ),
                      value: selectedShift,
                      items: const [
                        DropdownMenuItem(value: 'Morning (6 AM - 2 PM)', child: Text('Morning (6 AM - 2 PM)')),
                        DropdownMenuItem(value: 'Day (9 AM - 6 PM)', child: Text('Day (9 AM - 6 PM)')),
                        DropdownMenuItem(value: 'Evening (2 PM - 10 PM)', child: Text('Evening (2 PM - 10 PM)')),
                        DropdownMenuItem(value: 'Night (10 PM - 6 AM)', child: Text('Night (10 PM - 6 AM)')),
                      ],
                      onChanged: (value) {
                        setDialogState(() {
                          selectedShift = value;
                        });
                      },
                      validator: (value) => value == null ? 'Please select shift' : null,
                    ),
                    const SizedBox(height: 16),
                    
                    // Emergency Contact
                    TextFormField(
                      controller: emergencyController,
                      decoration: const InputDecoration(
                        labelText: 'Emergency Contact Number *',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.emergency),
                        prefixText: '+91 ',
                        hintText: '9876543210',
                      ),
                      keyboardType: TextInputType.phone,
                      maxLength: 10,
                      validator: (value) {
                        if (value == null || value.isEmpty) {
                          return 'Please enter emergency contact';
                        }
                        if (value.length != 10) {
                          return 'Please enter valid 10-digit number';
                        }
                        return null;
                      },
                    ),
                    const SizedBox(height: 16),
                    
                    // Blood Group
                    DropdownButtonFormField<String>(
                      decoration: const InputDecoration(
                        labelText: 'Blood Group',
                        border: OutlineInputBorder(),
                        prefixIcon: Icon(Icons.bloodtype),
                      ),
                      value: selectedBloodGroup,
                      items: const [
                        DropdownMenuItem(value: 'A+', child: Text('A+')),
                        DropdownMenuItem(value: 'A-', child: Text('A-')),
                        DropdownMenuItem(value: 'B+', child: Text('B+')),
                        DropdownMenuItem(value: 'B-', child: Text('B-')),
                        DropdownMenuItem(value: 'O+', child: Text('O+')),
                        DropdownMenuItem(value: 'O-', child: Text('O-')),
                        DropdownMenuItem(value: 'AB+', child: Text('AB+')),
                        DropdownMenuItem(value: 'AB-', child: Text('AB-')),
                      ],
                      onChanged: (value) {
                        setDialogState(() {
                          selectedBloodGroup = value;
                        });
                      },
                    ),
                  ],
                ),
              ),
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.pop(context),
              child: const Text('Cancel'),
            ),
            ElevatedButton(
              onPressed: () {
                if (formKey.currentState!.validate()) {
                  // Add employee creation logic here
                  Navigator.pop(context);
                  ScaffoldMessenger.of(this.context).showSnackBar(
                    const SnackBar(
                      content: Text('Employee added successfully!'),
                      backgroundColor: Color(0xFF10b981),
                    ),
                  );
                }
              },
              style: ElevatedButton.styleFrom(
                backgroundColor: const Color(0xFF10b981),
                padding: const EdgeInsets.symmetric(horizontal: 24, vertical: 12),
              ),
              child: const Text('Add Employee'),
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildRecentActivity() {
    return Container(
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(
          color: Colors.black.withOpacity(0.05),
        ),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.04),
            blurRadius: 8,
            offset: const Offset(0, 2),
          ),
        ],
      ),
      child: Padding(
        padding: const EdgeInsets.all(24),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const Text(
              'Recent Activity',
              style: TextStyle(
                fontSize: 18,
                fontWeight: FontWeight.bold,
                color: Color(0xFF1e293b),
              ),
            ),
            const SizedBox(height: 20),
            _buildActivityItem(
              'Trip TRP-5230 completed',
              '2 mins ago',
              Icons.check_circle,
              const Color(0xFF10b981),
            ),
            _buildActivityItem(
              'New employee added',
              '15 mins ago',
              Icons.person_add,
              const Color(0xFF2563eb),
            ),
            _buildActivityItem(
              'Roster RST-045 activated',
              '1 hour ago',
              Icons.calendar_month,
              const Color(0xFF2563eb),
            ),
            _buildActivityItem(
              'Invoice generated',
              '2 hours ago',
              Icons.receipt,
              const Color(0xFFf59e0b),
            ),
            _buildActivityItem(
              'Route optimized',
              '3 hours ago',
              Icons.route,
              const Color(0xFF10b981),
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildActivityItem(
    String text,
    String time,
    IconData icon,
    Color color,
  ) {
    return Padding(
      padding: const EdgeInsets.only(bottom: 16),
      child: Row(
        children: [
          Container(
            width: 32,
            height: 32,
            decoration: BoxDecoration(
              color: color.withOpacity(0.1),
              borderRadius: BorderRadius.circular(8),
            ),
            child: Icon(
              icon,
              size: 16,
              color: color,
            ),
          ),
          const SizedBox(width: 12),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  text,
                  style: const TextStyle(
                    fontSize: 14,
                    color: Color(0xFF1e293b),
                  ),
                ),
                Text(
                  time,
                  style: const TextStyle(
                    fontSize: 12,
                    color: Color(0xFF64748b),
                  ),
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildLiveTripMonitor() {
    return Container(
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(
          color: Colors.black.withOpacity(0.05),
        ),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.04),
            blurRadius: 8,
            offset: const Offset(0, 2),
          ),
        ],
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          // Header
          Padding(
            padding: const EdgeInsets.all(24),
            child: Row(
              mainAxisAlignment: MainAxisAlignment.spaceBetween,
              children: [
                const Text(
                  'Live Trip Monitor',
                  style: TextStyle(
                    fontSize: 18,
                    fontWeight: FontWeight.bold,
                    color: Color(0xFF1e293b),
                  ),
                ),
                ElevatedButton(
                  onPressed: () {
                    ScaffoldMessenger.of(context).showSnackBar(
                      const SnackBar(content: Text('Opening all trips...')),
                    );
                  },
                  style: ElevatedButton.styleFrom(
                    backgroundColor: const Color(0xFF2563eb),
                    elevation: 0,
                    padding: const EdgeInsets.symmetric(
                      horizontal: 20,
                      vertical: 12,
                    ),
                    shape: RoundedRectangleBorder(
                      borderRadius: BorderRadius.circular(8),
                    ),
                  ),
                  child: const Text(
                    'View All',
                    style: TextStyle(
                      fontSize: 14,
                      fontWeight: FontWeight.w600,
                    ),
                  ),
                ),
              ],
            ),
          ),
          
          // Table
          SingleChildScrollView(
            scrollDirection: Axis.horizontal,
            child: DataTable(
              columnSpacing: 24,
              horizontalMargin: 24,
              headingRowColor: MaterialStateProperty.all(
                const Color(0xFFf8fafc),
              ),
              columns: const [
                DataColumn(label: Text('Trip ID', style: TextStyle(fontWeight: FontWeight.w700))),
                DataColumn(label: Text('Employee', style: TextStyle(fontWeight: FontWeight.w700))),
                DataColumn(label: Text('Route', style: TextStyle(fontWeight: FontWeight.w700))),
                DataColumn(label: Text('Driver', style: TextStyle(fontWeight: FontWeight.w700))),
                DataColumn(label: Text('ETA', style: TextStyle(fontWeight: FontWeight.w700))),
                DataColumn(label: Text('Status', style: TextStyle(fontWeight: FontWeight.w700))),
                DataColumn(label: Text('Actions', style: TextStyle(fontWeight: FontWeight.w700))),
              ],
              rows: _getLiveTripRows(),
            ),
          ),
          const SizedBox(height: 16),
        ],
      ),
    );
  }

  List<DataRow> _getLiveTripRows() {
    final trips = [
      ['TRP-5234', 'Rajesh Kumar', 'Hitech → Campus', 'Suresh K.', '10 mins'],
      ['TRP-5235', 'Priya Sharma', 'Madhapur → Campus', 'Ramesh M.', '15 mins'],
      ['TRP-5236', 'Amit Patel', 'KPHB → Campus', 'Vijay R.', '20 mins'],
      ['TRP-5237', 'Sneha Singh', 'Kondapur → Campus', 'Kumar S.', '8 mins'],
    ];

    return trips.map((trip) {
      return DataRow(
        cells: [
          DataCell(Text(trip[0], style: const TextStyle(fontWeight: FontWeight.w600))),
          DataCell(Text(trip[1])),
          DataCell(Text(trip[2], style: const TextStyle(fontSize: 12))),
          DataCell(Text(trip[3])),
          DataCell(
            Container(
              padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
              decoration: BoxDecoration(
                color: const Color(0xFF2563eb).withOpacity(0.1),
                borderRadius: BorderRadius.circular(6),
              ),
              child: Text(
                trip[4],
                style: const TextStyle(
                  color: Color(0xFF2563eb),
                  fontSize: 12,
                  fontWeight: FontWeight.w600,
                ),
              ),
            ),
          ),
          DataCell(
            Container(
              padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
              decoration: BoxDecoration(
                color: const Color(0xFFf59e0b).withOpacity(0.1),
                borderRadius: BorderRadius.circular(6),
              ),
              child: const Text(
                'Ongoing',
                style: TextStyle(
                  color: Color(0xFFf59e0b),
                  fontSize: 12,
                  fontWeight: FontWeight.w600,
                ),
              ),
            ),
          ),
          DataCell(
            Row(
              mainAxisSize: MainAxisSize.min,
              children: [
                IconButton(
                  icon: const Icon(Icons.map, size: 18),
                  color: const Color(0xFF2563eb),
                  onPressed: () {
                    ScaffoldMessenger.of(context).showSnackBar(
                      SnackBar(content: Text('Tracking ${trip[0]}...')),
                    );
                  },
                  tooltip: 'Track',
                ),
                IconButton(
                  icon: const Icon(Icons.phone, size: 18),
                  color: const Color(0xFF10b981),
                  onPressed: () {
                    ScaffoldMessenger.of(context).showSnackBar(
                      SnackBar(content: Text('Calling ${trip[3]}...')),
                    );
                  },
                  tooltip: 'Call',
                ),
              ],
            ),
          ),
        ],
      );
    }).toList();
  }
}

class StatCard {
  final IconData icon;
  final Color iconColor;
  final Color iconBg;
  final String value;
  final String label;
  final String change;
  final bool changePositive;

  StatCard({
    required this.icon,
    required this.iconColor,
    required this.iconBg,
    required this.value,
    required this.label,
    required this.change,
    required this.changePositive,
  });
}

class EnhancedStatCard {
  final IconData icon;
  final Color iconColor;
  final Color iconBg;
  final String value;
  final String label;
  final String change;
  final bool changePositive;
  final List<FlSpot> trend;

  EnhancedStatCard({
    required this.icon,
    required this.iconColor,
    required this.iconBg,
    required this.value,
    required this.label,
    required this.change,
    required this.changePositive,
    required this.trend,
  });
}
