  // Helper functions
  String _formatTime(DateTime dateTime) {
    final hour = dateTime.hour.toString().padLeft(2, '0');
    final minute = dateTime.minute.toString().padLeft(2, '0');
    return '$hour:$minute';
  }

  String _formatFullDateTime(DateTime dateTime) {
    return DateFormat('MMM dd, yyyy hh:mm a').format(dateTime);
  }
  
  String _calculateTrend(List<dynamic> currentData, List<dynamic> previousData, String period) {
    if (previousData.isEmpty) return '+${currentData.length} $period';
    final currentCount = currentData.length;
    final previousCount = previousData.length;
    final difference = currentCount - previousCount;
    if (difference > 0) return '+$difference $period';
    if (difference < 0) return '$difference $period';
    return 'No change';
  }

  List<dynamic> _getDataFromTimeRange(List<dynamic> allData, DateTime startDate, DateTime endDate) {
    return allData.where((item) {
      DateTime? itemDate = _getItemDate(item);
      return itemDate != null && itemDate.isAfter(startDate) && itemDate.isBefore(endDate.add(const Duration(days: 1)));
    }).toList();
  }

  DateTime? _getItemDate(dynamic item) {
    // Try to get actual date from item properties
    if (item is Map) {
      // Try different possible date field names
      final dateFields = ['createdAt', 'created_at', 'date', 'timestamp', 'updatedAt'];
      for (final field in dateFields) {
        if (item.containsKey(field) && item[field] != null) {
          try {
            if (item[field] is DateTime) {
              return item[field] as DateTime;
            } else if (item[field] is String) {
              return DateTime.parse(item[field] as String);
            }
          } catch (e) {
            // Continue to next field if parsing fails
          }
        }
      }
    }
    // Fallback to current time if no date found
    return DateTime.now();
  }

