class DashboardSummaryItem {
  final String title;
  final String value;
  final IconData icon;
  final Color iconColor;
  final Color backgroundColor;
  final String? subtitle;
  final String? trend;
  final bool isIncreasing;
  final VoidCallback? onTap;

  const DashboardSummaryItem({
    required this.title,
    required this.value,
    required this.icon,
    required this.iconColor,
    required this.backgroundColor,
    this.subtitle,
    this.trend,
    this.isIncreasing = true,
    this.onTap,
  });
}

class AdminDashboardScreen extends StatefulWidget {
  // Callback to parent widget to change tabs
  final Function(int tabIndex)? onNavigateRequest; 

  const AdminDashboardScreen({
    super.key,
    this.onNavigateRequest,
  });

  @override
  State<AdminDashboardScreen> createState() => _AdminDashboardScreenState();
}

class _AdminDashboardScreenState extends State<AdminDashboardScreen> with ErrorHandlerMixin {
  // Safe API Service
  final SafeApiService _safeApi = SafeApiService();
  
  // Permission Service
  final PermissionService _permissionService = PermissionService();
  
  // Company Analytics Variables
  Map<String, dynamic> _companyAnalytics = {};
  List<Map<String, dynamic>> _mostActiveCompanies = [];
  bool _isLoadingCompanyData = false;
  
  // Company Employee Chart Data
  List<Map<String, dynamic>> _companyEmployeeData = [];
  bool _isLoadingChartData = false;
  
  // Manpower Overview Variables
  Map<String, int> _manpowerStats = {
    'totalCustomers': 0,
    'totalDrivers': 0,
    'totalClients': 0,
    'pendingRosters': 0,
    'ongoingRosters': 0,
    'activeTrips': 0,
    'completedTripsToday': 0,
    'cancelledTripsToday': 0,
  };
  
  // Revenue and Performance Variables
  Map<String, double> _revenueStats = {
    'todayRevenue': 0.0,
    'weekRevenue': 0.0,
    'monthRevenue': 0.0,
  };
  
  // Filter Variables
  String _selectedTimeFilter = 'today'; // today, week, month
  String _selectedCompanyFilter = 'all';

  // Roster Variables
  RosterService? _rosterService;
  RosterStats _rosterStats = RosterStats.empty();
  bool _isLoadingRosterStats = false;

  // Real-time Data Timer
  Timer? _realTimeUpdateTimer;

  // Driver Ratings
  double _averageDriverRating = 0.0;
  bool _isLoadingRatings = false;

  // Recent Activities - FROM BACKEND
  List<RecentActivity> _recentActivities = [];
  bool _isLoadingActivities = false;

  // Connection Status
  bool _isOnline = true;

  @override
  void initState() {
    super.initState();
    // Note: Don't access context.read in initState, do it in didChangeDependencies
  }

  @override
  void didChangeDependencies() {
    super.didChangeDependencies();
    
    // Initialize services here where context is available
    if (_rosterService == null) {
      try {
        // Get ApiService through BackendConnectionManager
        final connectionManager = context.read<BackendConnectionManager>();
        final apiService = connectionManager.apiService;
        _rosterService = RosterService(apiService: apiService);
      } catch (e) {
        debugPrint('❌ Error initializing RosterService: $e');
        // Fallback: Create a new BackendConnectionManager instance
        final connectionManager = BackendConnectionManager();
        final apiService = connectionManager.apiService;
        _rosterService = RosterService(apiService: apiService);
      }

      // Initial Data Load
      _refreshDashboard();

      // Setup Periodic Timer for Real-time updates (Every 30 seconds)
      _realTimeUpdateTimer = Timer.periodic(const Duration(seconds: 30), (timer) {
        if (mounted) {
          _refreshDashboard();
        }
      });
    }
  }

  @override
  void dispose() {
    // Cancel all subscriptions and timers first
    _realTimeUpdateTimer?.cancel();

    // Call super.dispose() last
    super.dispose();
  }

  Future<void> _refreshDashboard() async {
    // Check if widget is still mounted and active before accessing providers
    if (!mounted) return;
    
    // ✅ CHECK CIRCUIT BREAKER BEFORE MAKING REQUESTS
    if (!canMakeRequest) {
      debugPrint('⛔ Circuit breaker is open, skipping dashboard refresh');
      if (mounted) {
        setState(() {}); // Trigger rebuild to show banner
      }
      return;
    }
    
    // Check connection status first
    _checkConnectionStatus();
    
    // Reload all backend data with safe API calls
    _loadRosterStats();
    _loadCompanyAnalytics();
    _loadManpowerStats();
    _loadRevenueStats();
    _loadDriverRatings();
    _loadRecentActivities(); // NEW: Load real activities from backend
    _loadCompanyEmployeeData(); // ADD THIS LINE
  }

  Future<void> _checkConnectionStatus() async {
    try {
      final isOnline = await _safeApi.isOnline();
      if (mounted && _isOnline != isOnline) {
        setState(() {
          _isOnline = isOnline;
        });
        
        if (!isOnline) {
          debugPrint('📡 Backend is offline, using cached data');
        } else {
          debugPrint('📡 Backend is online');
        }
      }
    } catch (e) {
      handleSilentError(e, context: 'Connection Status Check');
    }
  }

  // ADD THIS METHOD TO FETCH COMPANY-EMPLOYEE DATA
  Future<void> _loadCompanyEmployeeData() async {
    if (!mounted) return;
    
    setState(() => _isLoadingChartData = true);
    
    try {
      final response = await _safeApi.safeGet(
        '/api/admin/analytics/company-employee-stats',
        context: 'Company Employee Data',
        fallback: {'success': false, 'companies': []},
      );

      if (response['success'] == true && mounted) {
        setState(() {
          _companyEmployeeData = List<Map<String, dynamic>>.from(response['companies'] ?? []);
          // Sort by employee count in descending order
          _companyEmployeeData.sort((a, b) => (b['totalEmployees'] ?? 0).compareTo(a['totalEmployees'] ?? 0));
          // Take top 10 only
          if (_companyEmployeeData.length > 10) {
            _companyEmployeeData = _companyEmployeeData.sublist(0, 10);
          }
          _isLoadingChartData = false;
        });
      } else if (mounted) {
        setState(() => _isLoadingChartData = false);
      }
    } catch (e) {
      handleSilentError(e, context: 'Company Employee Data');
      if (mounted) {
        setState(() => _isLoadingChartData = false);
      }
    }
  }

  Future<void> _loadRosterStats() async {
    // Check if service is initialized
    if (_rosterService == null) return;
    
    // Only show loading indicator on first load to prevent flickering
    if (_rosterStats.total == 0) {
      setState(() => _isLoadingRosterStats = true);
    }

    try {
      final stats = await _rosterService!.getRosterStats();
      if (mounted) {
        setState(() {
          _rosterStats = stats;
          _isLoadingRosterStats = false;
        });
      }
    } catch (e) {
      handleSilentError(e, context: 'Roster Stats');
      if (mounted) {
        setState(() => _isLoadingRosterStats = false);
      }
    }
  }

  Future<void> _loadCompanyAnalytics() async {
    if (!mounted) return;
    
    setState(() => _isLoadingCompanyData = true);
    
    try {
      final response = await _safeApi.safeGet(
        '/api/admin/analytics/company-analytics',
        queryParams: {
          'filter': _selectedTimeFilter,
          'company': _selectedCompanyFilter,
        },
        context: 'Company Analytics',
        fallback: {'success': false, 'analytics': {}, 'mostActive': []},
      );

      if (response['success'] == true && mounted) {
        setState(() {
          _companyAnalytics = response['analytics'] ?? {};
          _mostActiveCompanies = List<Map<String, dynamic>>.from(response['mostActive'] ?? []);
          _isLoadingCompanyData = false;
        });
      } else if (mounted) {
        setState(() => _isLoadingCompanyData = false);
      }
    } catch (e) {
      handleSilentError(e, context: 'Company Analytics');
      if (mounted) {
        setState(() => _isLoadingCompanyData = false);
      }
    }
  }

  Future<void> _loadManpowerStats() async {
    if (!mounted) return;
    
    try {
      final response = await _safeApi.safeGet(
        '/api/admin/analytics/manpower-stats',
        context: 'Manpower Stats',
        fallback: {'success': false, 'stats': {}},
      );

      if (response['success'] == true && mounted) {
        setState(() {
          _manpowerStats = Map<String, int>.from(response['stats'] ?? {});
        });
      }
    } catch (e) {
      handleSilentError(e, context: 'Manpower Stats');
    }
  }

  Future<void> _loadRevenueStats() async {
    if (!mounted) return;
    
    try {
      final response = await _safeApi.safeGet(
        '/api/admin/analytics/revenue-stats',
        queryParams: {'filter': _selectedTimeFilter},
        context: 'Revenue Stats',
        fallback: {'success': false, 'revenue': {}},
      );

      if (response['success'] == true && mounted) {
        setState(() {
          _revenueStats = Map<String, double>.from(response['revenue'] ?? {});
        });
      }
    } catch (e) {
      handleSilentError(e, context: 'Revenue Stats');
    }
  }

  Future<void> _loadDriverRatings() async {
    if (!mounted) return;
    
    setState(() => _isLoadingRatings = true);
    
    try {
      final response = await _safeApi.safeGet(
        '/api/admin/ratings/average',
        context: 'Driver Ratings',
        fallback: {'success': false, 'averageRating': 0.0},
      );

      if (response['success'] == true && mounted) {
        setState(() {
          _averageDriverRating = (response['averageRating'] ?? 0.0).toDouble();
          _isLoadingRatings = false;
        });
      } else if (mounted) {
        setState(() => _isLoadingRatings = false);
      }
    } catch (e) {
      handleSilentError(e, context: 'Driver Ratings');
      if (mounted) {
        setState(() => _isLoadingRatings = false);
      }
    }
  }

  Future<void> _loadRecentActivities() async {
    if (!mounted) return;
    
    setState(() => _isLoadingActivities = true);
    
    try {
      final activities = await RecentActivitiesService.fetchRecentActivities();
      if (mounted) {
        setState(() {
          _recentActivities = activities;
          _isLoadingActivities = false;
        });
      }
    } catch (e) {
      handleSilentError(e, context: 'Recent Activities');
      if (mounted) {
        setState(() => _isLoadingActivities = false);
      }
    }
  }

  void _onTimeFilterChanged(String filter) {
    setState(() {
      _selectedTimeFilter = filter;
    });
    _loadCompanyAnalytics();
    _loadRevenueStats();
  }

  void _onCompanyFilterChanged(String company) {
    setState(() {
      _selectedCompanyFilter = company;
    });
    _loadCompanyAnalytics();
  }

  // Company Analytics Dialog
  void _showCompanyAnalyticsDialog(BuildContext context) {
    showDialog(
      context: context,
      builder: (BuildContext context) {
        return AlertDialog(
          title: Row(
            children: [
              Icon(Icons.business, color: Colors.blue[700]),
              const SizedBox(width: 12),
              const Text('Company Analytics'),
            ],
          ),
          content: Container(
            width: double.maxFinite,
            constraints: const BoxConstraints(maxHeight: 500),
            child: _isLoadingCompanyData
                ? const Center(child: CircularProgressIndicator())
                : SingleChildScrollView(
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        _buildFilterSection(),
                        const SizedBox(height: 16),
                        _buildMostActiveCompaniesList(),
                      ],
                    ),
                  ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(),
              child: const Text('Close'),
            ),
          ],
        );
      },
    );
  }

  Widget _buildFilterSection() {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        const Text('Time Filter:', style: TextStyle(fontWeight: FontWeight.bold)),
        const SizedBox(height: 8),
        Wrap(
          spacing: 8,
          children: [
            FilterChip(
              label: const Text('Today'),
              selected: _selectedTimeFilter == 'today',
              onSelected: (selected) => _onTimeFilterChanged('today'),
            ),
            FilterChip(
              label: const Text('This Week'),
              selected: _selectedTimeFilter == 'week',
              onSelected: (selected) => _onTimeFilterChanged('week'),
            ),
            FilterChip(
              label: const Text('This Month'),
              selected: _selectedTimeFilter == 'month',
              onSelected: (selected) => _onTimeFilterChanged('month'),
            ),
          ],
        ),
      ],
    );
  }

  Widget _buildMostActiveCompaniesList() {
    if (_mostActiveCompanies.isEmpty) {
      return const Center(
        child: Text('No company data available'),
      );
    }

    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        const Text('Most Active Companies:', style: TextStyle(fontWeight: FontWeight.bold)),
        const SizedBox(height: 12),
        ListView.builder(
          shrinkWrap: true,
          physics: const NeverScrollableScrollPhysics(),
          itemCount: _mostActiveCompanies.length,
          itemBuilder: (context, index) {
            final company = _mostActiveCompanies[index];
            return _buildCompanyListItem(company, index);
          },
        ),
      ],
    );
  }

  Widget _buildCompanyListItem(Map<String, dynamic> company, int index) {
    final employeeBreakdown = company['employeeBreakdown'] as List<dynamic>? ?? [];
    final hasEmployees = employeeBreakdown.isNotEmpty;
    
    return Card(
      margin: const EdgeInsets.symmetric(vertical: 4),
      child: ExpansionTile(
        leading: CircleAvatar(
          backgroundColor: Colors.blue[100],
          child: Text('${index + 1}', style: TextStyle(color: Colors.blue[700], fontWeight: FontWeight.bold)),
        ),
        title: Text(
          company['name'] ?? 'Unknown Company',
          style: const TextStyle(fontWeight: FontWeight.w600),
        ),
        subtitle: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text('Employees: ${company['totalEmployees'] ?? 0}'),
            Text('Trips: ${company['completedTrips'] ?? 0} completed, ${company['cancelledTrips'] ?? 0} cancelled'),
            Text('Revenue: ₹${(company['revenue'] ?? 0.0).toStringAsFixed(2)}'),
            if (hasEmployees)
              Text(
                'Tap to view employee details',
                style: TextStyle(
                  fontSize: 12,
                  color: Colors.blue[600],
                  fontStyle: FontStyle.italic,
                ),
              ),
          ],
        ),
        trailing: Row(
          mainAxisSize: MainAxisSize.min,
          children: [
            Icon(Icons.trending_up, color: Colors.green[600]),
            if (hasEmployees) const Icon(Icons.expand_more),
          ],
        ),
        children: hasEmployees
            ? [_buildEmployeeBreakdownSection(employeeBreakdown, company)]
            : [
                const Padding(
                  padding: EdgeInsets.all(16.0),
                  child: Text(
                    'No employee trip data available for this period',
                    style: TextStyle(
                      fontStyle: FontStyle.italic,
                      color: Colors.grey,
                    ),
                  ),
                ),
              ],
      ),
    );
  }

  Widget _buildEmployeeBreakdownSection(List<dynamic> employeeBreakdown, Map<String, dynamic> company) {
    return Container(
      padding: const EdgeInsets.all(16),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              Icon(Icons.people, size: 20, color: Colors.blue[700]),
              const SizedBox(width: 8),
              Text(
                'Employee Trip Details',
                style: TextStyle(
                  fontWeight: FontWeight.bold,
                  color: Colors.blue[700],
                  fontSize: 16,
                ),
              ),
            ],
          ),
          const SizedBox(height: 12),
          if (employeeBreakdown.isEmpty)
            const Text(
              'No employees with trips in this period',
              style: TextStyle(
                fontStyle: FontStyle.italic,
                color: Colors.grey,
              ),
            )
          else
            ListView.separated(
              shrinkWrap: true,
              physics: const NeverScrollableScrollPhysics(),
              itemCount: employeeBreakdown.length,
              separatorBuilder: (context, index) => const Divider(height: 1),
              itemBuilder: (context, index) {
                final employee = employeeBreakdown[index] as Map<String, dynamic>;
                return _buildEmployeeDetailCard(employee);
              },
            ),
          const SizedBox(height: 8),
          TextButton.icon(
            onPressed: () => _showCompanyEmployeeDetails(company['name'] ?? 'Unknown Company'),
            icon: const Icon(Icons.visibility, size: 16),
            label: const Text('View All Employee Details'),
            style: TextButton.styleFrom(
              foregroundColor: Colors.blue[700],
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildEmployeeDetailCard(Map<String, dynamic> employee) {
    final completedTrips = employee['completedTrips'] ?? 0;
    final cancelledTrips = employee['cancelledTrips'] ?? 0;
    final totalTrips = employee['totalTrips'] ?? 0;
    final revenue = (employee['revenue'] ?? 0.0) as double;
    
    return Container(
      padding: const EdgeInsets.all(12),
      margin: const EdgeInsets.symmetric(vertical: 4),
      decoration: BoxDecoration(
        color: Colors.grey[50],
        borderRadius: BorderRadius.circular(8),
        border: Border.all(color: Colors.grey[200]!),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              CircleAvatar(
                radius: 16,
                backgroundColor: Colors.blue[100],
                child: Text(
                  (employee['name'] ?? 'N/A').toString().substring(0, 1).toUpperCase(),
                  style: TextStyle(
                    color: Colors.blue[700],
                    fontWeight: FontWeight.bold,
                    fontSize: 12,
                  ),
                ),
              ),
              const SizedBox(width: 12),
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(
                      employee['name'] ?? 'Unknown Employee',
                      style: const TextStyle(
                        fontWeight: FontWeight.w600,
                        fontSize: 14,
                      ),
                    ),
                    if (employee['department'] != null)
                      Text(
                        employee['department'],
                        style: TextStyle(
                          fontSize: 12,
                          color: Colors.grey[600],
                        ),
                      ),
                  ],
                ),
              ),
            ],
          ),
          const SizedBox(height: 8),
          Row(
            children: [
              Expanded(
                child: _buildEmployeeStatChip(
                  'Completed',
                  completedTrips.toString(),
                  Colors.green,
                  Icons.check_circle,
                ),
              ),
              const SizedBox(width: 8),
              Expanded(
                child: _buildEmployeeStatChip(
                  'Cancelled',
                  cancelledTrips.toString(),
                  Colors.red,
                  Icons.cancel,
                ),
              ),
            ],
          ),
          const SizedBox(height: 8),
          Row(
            children: [
              Expanded(
                child: _buildEmployeeStatChip(
                  'Total Trips',
                  totalTrips.toString(),
                  Colors.blue,
                  Icons.route,
                ),
              ),
              const SizedBox(width: 8),
              Expanded(
                child: _buildEmployeeStatChip(
                  'Revenue',
                  '₹${revenue.toStringAsFixed(0)}',
                  Colors.orange,
                  Icons.currency_rupee,
                ),
              ),
            ],
          ),
        ],
      ),
    );
  }

  Widget _buildEmployeeStatChip(String label, String value, Color color, IconData icon) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
      decoration: BoxDecoration(
        color: color.withOpacity(0.1),
        borderRadius: BorderRadius.circular(6),
        border: Border.all(color: color.withOpacity(0.3)),
      ),
      child: Row(
        mainAxisSize: MainAxisSize.min,
        children: [
          Icon(icon, size: 12, color: color),
          const SizedBox(width: 4),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  label,
                  style: TextStyle(
                    fontSize: 10,
                    color: color,
                    fontWeight: FontWeight.w500,
                  ),
                ),
                Text(
                  value,
                  style: TextStyle(
                    fontSize: 12,
                    color: color,
                    fontWeight: FontWeight.bold,
                  ),
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }

  void _showCompanyEmployeeDetails(String companyName) {
    // This method will show detailed employee analytics in a separate dialog
    showDialog(
      context: context,
      builder: (BuildContext context) {
        return AlertDialog(
          title: Row(
            children: [
              Icon(Icons.business, color: Colors.blue[700]),
              const SizedBox(width: 12),
              Expanded(
                child: Text('$companyName - Employee Details'),
              ),
            ],
          ),
          content: Container(
            width: double.maxFinite,
            constraints: const BoxConstraints(maxHeight: 600),
            child: const Center(
              child: Text(
                'Detailed employee analytics will be implemented here.\nThis will show comprehensive trip history, performance metrics, and individual employee statistics.',
                textAlign: TextAlign.center,
                style: TextStyle(fontStyle: FontStyle.italic),
              ),
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(),
              child: const Text('Close'),
            ),
          ],
        );
      },
    );
  }

  // Detailed Info Dialogs
  void _showTripsDetailDialog(BuildContext context, String tripType) {
    showDialog(
      context: context,
      builder: (BuildContext context) {
        return AlertDialog(
          title: Row(
            children: [
              Icon(
                tripType == 'active' ? Icons.route : 
                tripType == 'completed' ? Icons.check_circle : Icons.cancel,
                color: tripType == 'active' ? Colors.blue[700] : 
                       tripType == 'completed' ? Colors.green[700] : Colors.red[700],
              ),
              const SizedBox(width: 12),
              Text('${tripType.toUpperCase()} Trips Details'),
            ],
          ),
          content: Container(
            width: double.maxFinite,
            constraints: const BoxConstraints(maxHeight: 500),
            child: FutureBuilder<List<Map<String, dynamic>>>(
              future: _fetchTripDetails(tripType),
              builder: (context, snapshot) {
                if (snapshot.connectionState == ConnectionState.waiting) {
                  return const Center(child: CircularProgressIndicator());
                }
                
                if (snapshot.hasError) {
                  return Center(
                    child: Text('Error: ${snapshot.error}'),
                  );
                }
                
                final trips = snapshot.data ?? [];
                
                if (trips.isEmpty) {
                  return Center(
                    child: Column(
                      mainAxisAlignment: MainAxisAlignment.center,
                      children: [
                        Icon(
                          Icons.info_outline,
                          size: 48,
                          color: Colors.grey[400],
                        ),
                        const SizedBox(height: 16),
                        Text(
                          'No $tripType trips found',
                          style: TextStyle(
                            fontSize: 16,
                            color: Colors.grey[600],
                          ),
                        ),
                      ],
                    ),
                  );
                }
                
                return SingleChildScrollView(
                  child: Column(
                    children: trips.map((trip) => _buildTripDetailCard(trip, tripType)).toList(),
                  ),
                );
              },
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(),
              child: const Text('Close'),
            ),
            if (tripType == 'active')
              ElevatedButton.icon(
                onPressed: () {
                  Navigator.of(context).pop();
                  widget.onNavigateRequest?.call(5); // Navigate to trips management (was 6)
                },
                icon: const Icon(Icons.manage_search),
                label: const Text('Manage Trips'),
              ),
          ],
        );
      },
    );
  }

  void _showRatingsDetailDialog(BuildContext context) {
    showDialog(
      context: context,
      builder: (BuildContext context) {
        return AlertDialog(
          title: Row(
            children: [
              Icon(Icons.star, color: Colors.amber[700]),
              const SizedBox(width: 12),
              const Text('Driver Ratings Overview'),
            ],
          ),
          content: Container(
            width: double.maxFinite,
            constraints: const BoxConstraints(maxHeight: 500),
            child: FutureBuilder<Map<String, dynamic>>(
              future: _fetchRatingsDetails(),
              builder: (context, snapshot) {
                if (snapshot.connectionState == ConnectionState.waiting) {
                  return const Center(child: CircularProgressIndicator());
                }
                
                if (snapshot.hasError) {
                  return Center(
                    child: Text('Error: ${snapshot.error}'),
                  );
                }
                
                final ratingsData = snapshot.data ?? {};
                
                return SingleChildScrollView(
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      _buildRatingsOverview(ratingsData),
                      const SizedBox(height: 16),
                      const Divider(),
                      const SizedBox(height: 16),
                      _buildTopRatedDrivers(ratingsData['topDrivers'] ?? []),
                    ],
                  ),
                );
              },
            ),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(),
              child: const Text('Close'),
            ),
            ElevatedButton.icon(
              onPressed: () {
                Navigator.of(context).pop();
                widget.onNavigateRequest?.call(1); // Navigate to driver management (was 2)
              },
              icon: const Icon(Icons.people),
              label: const Text('Manage Drivers'),
            ),
          ],
        );
      },
    );
  }

