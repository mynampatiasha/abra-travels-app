  // Data Fetching Methods
  Future<List<Map<String, dynamic>>> _fetchTripDetails(String tripType) async {
    try {
      // Get JWT auth token from SharedPreferences
      final prefs = await SharedPreferences.getInstance();
      final token = prefs.getString('jwt_token');
      
      String endpoint;
      switch (tripType) {
        case 'active':
          endpoint = '/api/admin/trips/active';
          break;
        case 'completed':
          endpoint = '/api/admin/trips/completed-today';
          break;
        case 'cancelled':
          endpoint = '/api/admin/trips/cancelled-today';
          break;
        default:
          endpoint = '/api/admin/trips/active';
      }
      
      final response = await http.get(
        Uri.parse('${ApiConfig.baseUrl}$endpoint'),
        headers: {
          'Content-Type': 'application/json',
          if (token != null && token.isNotEmpty) 'Authorization': 'Bearer $token',
        },
      );

      if (response.statusCode == 200) {
        final data = json.decode(response.body);
        if (data['success'] == true) {
          return List<Map<String, dynamic>>.from(data['trips'] ?? []);
        }
      }
      return [];
    } catch (e) {
      debugPrint('Error fetching trip details: $e');
      return [];
    }
  }

  Future<Map<String, dynamic>> _fetchRatingsDetails() async {
    try {
      // Get JWT auth token from SharedPreferences
      final prefs = await SharedPreferences.getInstance();
      final token = prefs.getString('jwt_token');
      
      final response = await http.get(
        Uri.parse('${ApiConfig.baseUrl}/api/admin/ratings/overview'),
        headers: {
          'Content-Type': 'application/json',
          if (token != null && token.isNotEmpty) 'Authorization': 'Bearer $token',
        },
      );

      if (response.statusCode == 200) {
        final data = json.decode(response.body);
        if (data['success'] == true) {
          return data['ratingsData'] ?? {};
        }
      }
      return {};
    } catch (e) {
      debugPrint('Error fetching ratings details: $e');
      return {};
    }
  }

  Future<Map<String, dynamic>> _fetchRevenueDetails(String revenueType) async {
    try {
      // Get JWT auth token from SharedPreferences
      final prefs = await SharedPreferences.getInstance();
      final token = prefs.getString('jwt_token');
      
      final response = await http.get(
        Uri.parse('${ApiConfig.baseUrl}/api/admin/revenue/details?type=$revenueType'),
        headers: {
          'Content-Type': 'application/json',
          if (token != null && token.isNotEmpty) 'Authorization': 'Bearer $token',
        },
      );

      if (response.statusCode == 200) {
        final data = json.decode(response.body);
        if (data['success'] == true) {
          return data['revenueData'] ?? {};
        }
      }
      return {};
    } catch (e) {
      debugPrint('Error fetching revenue details: $e');
      return {};
    }
  }

  // UI Builder Methods for Dialogs
  Widget _buildTripDetailCard(Map<String, dynamic> trip, String tripType) {
    final tripId = trip['tripId'] ?? trip['_id'] ?? 'Unknown';
    final customerName = trip['customerName'] ?? trip['customer']?['name'] ?? 'Unknown Customer';
    final driverName = trip['driverName'] ?? trip['driver']?['name'] ?? 'Unknown Driver';
    final vehicleNumber = trip['vehicleNumber'] ?? trip['vehicle']?['vehicleNumber'] ?? 'Unknown Vehicle';
    final pickupLocation = trip['pickupLocation'] ?? trip['pickup']?['address'] ?? 'Unknown Pickup';
    final dropLocation = trip['dropLocation'] ?? trip['drop']?['address'] ?? 'Unknown Drop';
    final fare = trip['fare'] ?? 0.0;
    final status = trip['status'] ?? 'unknown';
    
    Color statusColor;
    IconData statusIcon;
    
    switch (status.toLowerCase()) {
      case 'completed':
        statusColor = Colors.green;
        statusIcon = Icons.check_circle;
        break;
      case 'cancelled':
        statusColor = Colors.red;
        statusIcon = Icons.cancel;
        break;
      case 'in_progress':
      case 'ongoing':
        statusColor = Colors.blue;
        statusIcon = Icons.directions_car;
        break;
      case 'scheduled':
        statusColor = Colors.orange;
        statusIcon = Icons.schedule;
        break;
      default:
        statusColor = Colors.grey;
        statusIcon = Icons.help_outline;
    }

    return Card(
      margin: const EdgeInsets.symmetric(vertical: 4),
      child: Padding(
        padding: const EdgeInsets.all(12),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Row(
              mainAxisAlignment: MainAxisAlignment.spaceBetween,
              children: [
                Expanded(
                  child: Text(
                    'Trip ID: $tripId',
                    style: const TextStyle(
                      fontWeight: FontWeight.bold,
                      fontSize: 14,
                    ),
                  ),
                ),
                Container(
                  padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                  decoration: BoxDecoration(
                    color: statusColor.withOpacity(0.1),
                    borderRadius: BorderRadius.circular(12),
                    border: Border.all(color: statusColor.withOpacity(0.3)),
                  ),
                  child: Row(
                    mainAxisSize: MainAxisSize.min,
                    children: [
                      Icon(statusIcon, size: 12, color: statusColor),
                      const SizedBox(width: 4),
                      Text(
                        status.toUpperCase(),
                        style: TextStyle(
                          fontSize: 10,
                          fontWeight: FontWeight.bold,
                          color: statusColor,
                        ),
                      ),
                    ],
                  ),
                ),
              ],
            ),
            const SizedBox(height: 8),
            _buildTripInfoRow(Icons.person, 'Customer', customerName),
            _buildTripInfoRow(Icons.drive_eta, 'Driver', driverName),
            _buildTripInfoRow(Icons.directions_car, 'Vehicle', vehicleNumber),
            _buildTripInfoRow(Icons.location_on, 'Pickup', pickupLocation),
            _buildTripInfoRow(Icons.flag, 'Drop', dropLocation),
            if (fare > 0)
              _buildTripInfoRow(Icons.currency_rupee, 'Fare', '₹${fare.toStringAsFixed(2)}'),
          ],
        ),
      ),
    );
  }

