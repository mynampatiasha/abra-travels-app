                  ),
                ),
                const Spacer(),
                if (_isLoadingTrips)
                  const SizedBox(
                    width: 20,
                    height: 20,
                    child: CircularProgressIndicator(strokeWidth: 2),
                  )
                else
                  IconButton(
                    icon: const Icon(Icons.refresh),
                    onPressed: _loadAdminTrips,
                    tooltip: 'Refresh',
                  ),
              ],
            ),
            const SizedBox(height: 16),
            
            if (_tripsError != null)
              Container(
                padding: const EdgeInsets.all(12),
                decoration: BoxDecoration(
                  color: Colors.red.shade50,
                  borderRadius: BorderRadius.circular(8),
                  border: Border.all(color: Colors.red.shade200),
                ),
                child: Row(
                  children: [
                    Icon(Icons.error_outline, color: Colors.red.shade700),
                    const SizedBox(width: 12),
                    Expanded(
                      child: Text(
                        _tripsError!,
                        style: TextStyle(color: Colors.red.shade700),
                      ),
                    ),
                  ],
                ),
              )
            else if (_adminTrips.isEmpty && !_isLoadingTrips)
              Container(
                padding: const EdgeInsets.all(24),
                alignment: Alignment.center,
                child: Column(
                  children: [
                    Icon(Icons.inbox_outlined, size: 64, color: Colors.grey.shade400),
                    const SizedBox(height: 16),
                    Text(
                      'No admin-assigned trips found',
                      style: TextStyle(
                        fontSize: 16,
                        color: Colors.grey.shade600,
                        fontWeight: FontWeight.w500,
                      ),
                    ),
                    const SizedBox(height: 8),
                    Text(
                      'Create a new trip to see it here',
                      style: TextStyle(
                        fontSize: 14,
                        color: Colors.grey.shade500,
                      ),
                    ),
                  ],
                ),
              )
            else
              SingleChildScrollView(
                scrollDirection: Axis.horizontal,
                child: DataTable(
                  headingRowColor: MaterialStateProperty.all(Colors.grey.shade100),
                  columns: const [
                    DataColumn(label: Text('Trip #', style: TextStyle(fontWeight: FontWeight.bold))),
                    DataColumn(label: Text('Vehicle', style: TextStyle(fontWeight: FontWeight.bold))),
                    DataColumn(label: Text('Driver', style: TextStyle(fontWeight: FontWeight.bold))),
                    DataColumn(label: Text('Distance', style: TextStyle(fontWeight: FontWeight.bold))),
                    DataColumn(label: Text('Pickup Time', style: TextStyle(fontWeight: FontWeight.bold))),
                    DataColumn(label: Text('Status', style: TextStyle(fontWeight: FontWeight.bold))),
                    DataColumn(label: Text('Actions', style: TextStyle(fontWeight: FontWeight.bold))),
                  ],
                  rows: _adminTrips.map((trip) {
                    return DataRow(
                      cells: [
                        DataCell(
                          Text(
                            trip['tripNumber'] ?? 'N/A',
                            style: const TextStyle(fontWeight: FontWeight.w600),
                          ),
                        ),
                        DataCell(
                          Text(trip['vehicleNumber'] ?? 'N/A'),
                        ),
                        DataCell(
                          Column(
                            crossAxisAlignment: CrossAxisAlignment.start,
                            mainAxisAlignment: MainAxisAlignment.center,
                            children: [
                              Text(
                                trip['driverName'] ?? 'N/A',
                                style: const TextStyle(fontWeight: FontWeight.w500),
                              ),
                              if (trip['driverPhone'] != null)
                                Text(
                                  trip['driverPhone'],
                                  style: TextStyle(
                                    fontSize: 12,
                                    color: Colors.grey.shade600,
                                  ),
                                ),
                            ],
                          ),
                        ),
                        DataCell(
                          Text('${trip['distance']?.toStringAsFixed(1) ?? '0'} km'),
                        ),
                        DataCell(
                          Text(_formatDateTime(trip['scheduledPickupTime'])),
                        ),
                        DataCell(
                          _buildStatusChip(trip['status'] ?? 'unknown'),
                        ),
                        DataCell(
                          Row(
                            mainAxisSize: MainAxisSize.min,
                            children: [
                              IconButton(
                                icon: const Icon(Icons.visibility, size: 20),
                                onPressed: () => _showTripDetails(trip),
                                tooltip: 'View Details',
                                color: Colors.blue.shade700,
                              ),
                              IconButton(
                                icon: const Icon(Icons.map, size: 20),
                                onPressed: () => _trackTrip(trip),
                                tooltip: 'Track on Map',
                                color: Colors.green.shade700,
                              ),
