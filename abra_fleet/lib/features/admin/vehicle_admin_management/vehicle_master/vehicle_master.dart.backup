  void _showStatusFilterDialog() {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),
        title: const Text('Filter by Status'),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            _buildFilterOption('All', _selectedStatusFilter, (value) {
              setState(() {
                _selectedStatusFilter = value;
                _applyFilters();
              });
              Navigator.pop(context);
            }),
            _buildFilterOption('Active', _selectedStatusFilter, (value) {
              setState(() {
                _selectedStatusFilter = value;
                _applyFilters();
              });
              Navigator.pop(context);
            }),
            _buildFilterOption('Maintenance', _selectedStatusFilter, (value) {
              setState(() {
                _selectedStatusFilter = value;
                _applyFilters();
              });
              Navigator.pop(context);
            }),
            _buildFilterOption('Inactive', _selectedStatusFilter, (value) {
              setState(() {
                _selectedStatusFilter = value;
                _applyFilters();
              });
              Navigator.pop(context);
            }),
          ],
        ),
      ),
    );
  }

