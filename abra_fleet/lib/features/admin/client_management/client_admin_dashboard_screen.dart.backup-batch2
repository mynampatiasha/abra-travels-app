  // Apply local filters to employees
  List<Map<String, dynamic>> _getFilteredEmployees() {
    if (_activeFilters.isEmpty) return _companyEmployees;
    
    return _companyEmployees.where((employee) {
      // Date range filter
      if (_activeFilters.containsKey('startDate') && _activeFilters.containsKey('endDate')) {
        final startDate = _activeFilters['startDate'] as DateTime;
        final endDate = _activeFilters['endDate'] as DateTime;
        final employeeDate = _parseDate(employee['createdAt'] ?? employee['registrationDate']);
        if (employeeDate == null || 
            employeeDate.isBefore(startDate) || 
            employeeDate.isAfter(endDate)) {
          return false;
        }
      }
      
      // State filter
      if (_activeFilters.containsKey('state')) {
        final state = _activeFilters['state'] as String;
        if (employee['state']?.toString().toLowerCase() != state.toLowerCase()) {
          return false;
        }
      }
      
      // City filter
      if (_activeFilters.containsKey('city')) {
        final city = _activeFilters['city'] as String;
        final employeeCity = employee['city']?.toString() ?? '';
        if (!employeeCity.toLowerCase().contains(city.toLowerCase())) {
          return false;
        }
      }
      
      // Area filter
      if (_activeFilters.containsKey('area')) {
        final area = _activeFilters['area'] as String;
        final employeeArea = employee['area']?.toString() ?? '';
        if (!employeeArea.toLowerCase().contains(area.toLowerCase())) {
          return false;
        }
      }
      
      return true;
    }).toList();
  }
  
  DateTime? _parseDate(dynamic timestamp) {
    if (timestamp == null) return null;
    
    try {
      if (timestamp is String) {
        return DateTime.parse(timestamp);
      } else if (timestamp is int) {
        return DateTime.fromMillisecondsSinceEpoch(timestamp);
      } else if (timestamp is DateTime) {
        return timestamp;
      }
    } catch (e) {
      debugPrint('Error parsing date: $e');
    }
    return null;
  }

