                  const SizedBox(height: 16),
                  TextFormField(
                    controller: branchController,
                    decoration: const InputDecoration(
                      labelText: 'Branch Location (Optional)',
                      border: OutlineInputBorder(),
                      prefixIcon: Icon(Icons.location_city),
                      hintText: 'e.g., Bangalore, Chennai, Mumbai',
                    ),
                  ),
                  const SizedBox(height: 16),
                  TextFormField(
                    controller: panController,
                    decoration: const InputDecoration(
                      labelText: 'PAN Number (Optional)',
                      border: OutlineInputBorder(),
                      prefixIcon: Icon(Icons.credit_card),
                    ),
                    textCapitalization: TextCapitalization.characters,
                  ),
                ],
              ),
            ),
          ),
          actions: [
            TextButton(
              onPressed: isCreating ? null : () => Navigator.pop(context),
              child: const Text('Cancel'),
            ),
            ElevatedButton(
              onPressed: isCreating ? null : () async {
                if (!formKey.currentState!.validate()) {
                  return;
                }

                // Store values BEFORE starting the async operation
                final clientName = nameController.text.trim();
                final clientEmail = emailController.text.trim();
                final clientPassword = passwordController.text.trim();
                final clientPhone = phoneController.text.trim();
                final clientAddress = addressController.text.trim();
                final clientContactPerson = contactPersonController.text.trim();
                final clientBranch = branchController.text.trim().isNotEmpty 
                    ? branchController.text.trim() 
                    : null;
                final clientGst = gstController.text.trim().isNotEmpty 
                    ? gstController.text.trim() 
                    : null;
                final clientPan = panController.text.trim().isNotEmpty 
                    ? panController.text.trim() 
                    : null;

                setDialogState(() => isCreating = true);

                try {
                  await _createClient(
                    name: clientName,
                    email: clientEmail,
                    password: clientPassword,
                    phone: clientPhone,
                    address: clientAddress,
                    contactPerson: clientContactPerson,
                    branch: clientBranch,
                    gstNumber: clientGst,
                    panNumber: clientPan,
                  );

                  // Pop the dialog first
                  if (!mounted) return;
                  Navigator.pop(context);
                  
                  // Wait for navigation to complete
                  await Future.delayed(const Duration(milliseconds: 300));
                  
                  // Show success message and reload
                  if (!mounted) return;
                  
                  ScaffoldMessenger.of(context).showSnackBar(
                    SnackBar(
                      content: Text(
                        '✅ Client "$clientName" created successfully!\n'
                        '📧 Email: $clientEmail\n'
                        '🔑 Password: $clientPassword\n'
                        '👤 Role: Client Organization',
                      ),
                      backgroundColor: Colors.green,
                      duration: const Duration(seconds: 6),
                    ),
                  );
                  
                  _loadClients();
                } catch (e) {
                  setDialogState(() => isCreating = false);
                  
                  String errorMessage = 'Error creating client account';
                  // Handle different error types
                  if (e.toString().contains('email-already-in-use')) {
                    errorMessage = '❌ This email is already registered';
                  } else if (e.toString().contains('weak-password')) {
                    errorMessage = '❌ Password is too weak (min 6 characters)';
                  } else if (e.toString().contains('invalid-email')) {
                    errorMessage = '❌ Invalid email address';
                  } else {
                    errorMessage = '❌ ${e.toString()}';
                  }
                  
                  if (!mounted) return;
                  
                  ScaffoldMessenger.of(context).showSnackBar(
                    SnackBar(
                      content: Text(errorMessage),
                      backgroundColor: Colors.red,
                      duration: const Duration(seconds: 5),
                    ),
                  );
                }
              },
              child: isCreating
                  ? const SizedBox(
                      width: 20,
                      height: 20,
                      child: CircularProgressIndicator(
                        strokeWidth: 2,
                        color: Colors.white,
                      ),
                    )
                  : const Text('Create Client'),
            ),
          ],
        ),
      ),
    );
  }

