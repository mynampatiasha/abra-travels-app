  List<Widget> _buildCustomersByCategory() {
    // Get filtered employees
    final filteredEmployees = _getFilteredEmployees();
    
    // Group customers by category type
    final Map<String, List<Map<String, dynamic>>> groupedCustomers = {};
    
    for (var customer in filteredEmployees) {
      final categoryType = customer['categoryType'] as String? ?? 'Unknown';
      if (!groupedCustomers.containsKey(categoryType)) {
        groupedCustomers[categoryType] = [];
      }
      groupedCustomers[categoryType]!.add(customer);
    }
    
    final List<Widget> categoryWidgets = [];
    
    // Define category order and colors
    final categoryOrder = [
      'Directly Assigned',
      'Domain Matched (@$_companyDomain)',
      'Company Matched',
    ];
    
    final categoryColors = {
      'Directly Assigned': Colors.green,
      'Domain Matched (@$_companyDomain)': Colors.blue,
      'Company Matched': Colors.orange,
    };
    
    for (String categoryType in categoryOrder) {
      if (groupedCustomers.containsKey(categoryType) && groupedCustomers[categoryType]!.isNotEmpty) {
        final customers = groupedCustomers[categoryType]!;
        final color = categoryColors[categoryType] ?? Colors.grey;
        
        categoryWidgets.add(
          ExpansionTile(
            leading: Icon(
              categoryType.contains('Directly') ? Icons.assignment_ind :
              categoryType.contains('Domain') ? Icons.domain : Icons.business,
              color: color,
            ),
            title: Text(
              '$categoryType (${customers.length})',
              style: const TextStyle(fontWeight: FontWeight.w600),
            ),
            subtitle: Text(
              _getCategoryDescription(categoryType),
              style: TextStyle(fontSize: 12, color: Colors.grey[600]),
            ),
            children: [
              ListView.builder(
                shrinkWrap: true,
                physics: const NeverScrollableScrollPhysics(),
                itemCount: customers.length,
                itemBuilder: (context, index) {
                  final customer = customers[index];
                  return ListTile(
                    leading: CircleAvatar(
                      backgroundColor: color.withOpacity(0.1),
                      child: Text(
                        (customer['name'] as String? ?? 'U')[0].toUpperCase(),
                        style: TextStyle(color: color, fontWeight: FontWeight.bold),
                      ),
                    ),
                    title: Text(customer['name'] ?? 'Unknown'),
                    subtitle: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Text(customer['email'] ?? ''),
                        if (customer['companyName'] != null && customer['companyName'].toString().isNotEmpty)
                          Text(
                            customer['companyName'].toString(),
                            style: TextStyle(fontSize: 12, color: Colors.grey[600]),
                          ),
                      ],
                    ),
                    trailing: customer['phoneNumber'] != null && customer['phoneNumber'].toString().isNotEmpty
                        ? IconButton(
                            icon: const Icon(Icons.phone),
                            onPressed: () {
                              // Handle phone call
                            },
                          )
                        : null,
                  );
                },
              ),
            ],
          ),
        );
        
        categoryWidgets.add(const SizedBox(height: 8));
      }
    }
    
    return categoryWidgets;
  }

  String _getCategoryDescription(String categoryType) {
    if (categoryType.contains('Directly')) {
      return 'Customers explicitly assigned to this client';
    } else if (categoryType.contains('Domain')) {
      return 'Employees with matching email domain';
    } else if (categoryType.contains('Company')) {
      return 'Customers matched by company name';
    }
    return 'Unknown category';
  }

