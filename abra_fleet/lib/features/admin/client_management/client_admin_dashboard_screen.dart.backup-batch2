  /// Count customers by domain for each client
  /// This method extracts the domain from each client's email and counts matching customers
  Future<void> _countCustomersByDomain() async {
    try {
      debugPrint('🔄 Counting customers by domain for each client...');
      
      final Map<String, int> counts = {};
      
      for (var client in _clients) {
        // Extract domain from client email
        // Example: admin@abrafleet.com → @abrafleet.com
        if (client.email.contains('@')) {
          final emailParts = client.email.split('@');
          if (emailParts.length == 2) {
            final domain = '@${emailParts[1]}';
            
            debugPrint('📧 Client: ${client.name} | Domain: $domain');
            
            // Count customers with matching domain
            final count = await _customerService.countCustomersByDomain(domain);
            counts[client.id] = count;
            
            debugPrint('   ✅ Found $count customers with domain $domain');
          }
        }
      }
      
      setState(() {
        _clientCustomerCounts = counts;
      });
      
      debugPrint('✅ Customer counts by domain completed');
      debugPrint('📊 Total clients processed: ${counts.length}');
      
    } catch (e) {
      debugPrint('❌ Error counting customers by domain: $e');
    }
  }

  Future<void> _loadClients() async {
    setState(() => _isLoading = true);
    
    try {
      debugPrint('📥 Loading clients using ClientService...');
      
      // Fetch all clients using ClientService
      final clients = await _clientService.getAllClients(limit: 100);
      
      // Sort by creation date (newest first)
      clients.sort((a, b) => b.createdAt.compareTo(a.createdAt));
      
      if (mounted) {
        setState(() {
          _clients = clients;
        });
        
        debugPrint('✅ Loaded ${clients.length} clients');
        
        // Count customers by domain for each client
        await _countCustomersByDomain();
        
        setState(() => _isLoading = false);
      }
    } catch (e) {
      debugPrint('❌ Error loading clients: $e');
      if (mounted) {
        setState(() => _isLoading = false);
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Error loading clients: $e'),
            backgroundColor: Colors.red,
          ),
        );
      }
    }
  }

  List<ClientModel> get _filteredClients {
    if (_searchQuery.isEmpty) return _clients;
    return _clients.where((client) {
      return client.name.toLowerCase().contains(_searchQuery.toLowerCase()) ||
             client.email.toLowerCase().contains(_searchQuery.toLowerCase()) ||
             client.phone.contains(_searchQuery);
    }).toList();
  }
  
  /// Get customer count for a client (from domain-based counting)
  int _getClientCustomerCount(ClientModel client) {
    return _clientCustomerCounts[client.id] ?? client.totalCustomers;
  }

