// ClientDetailsScreen with Employee Management Integration
class ClientDetailsScreen extends StatefulWidget {
  final ClientModel client;
  final VoidCallback onUpdate;

  const ClientDetailsScreen({
    super.key,
    required this.client,
    required this.onUpdate,
  });

  @override
  State<ClientDetailsScreen> createState() => _ClientDetailsScreenState();
}

class _ClientDetailsScreenState extends State<ClientDetailsScreen> {
  List<Map<String, dynamic>> _companyEmployees = [];
  bool _isLoadingEmployees = true;
  String _companyDomain = '';
  Map<String, dynamic> _companyStats = {};
  Map<String, dynamic> _activeFilters = {}; // For horizontal filter bar

  @override
  void initState() {
    super.initState();
    _extractCompanyDomain();
    _loadCompanyEmployees();
  }

  void _extractCompanyDomain() {
    // Extract domain from client email
    if (widget.client.email.contains('@')) {
      _companyDomain = widget.client.email.split('@')[1];
    }
    debugPrint('🏢 Client company domain: $_companyDomain');
  }

  Future<void> _loadCompanyEmployees() async {
    try {
      debugPrint('🔍 Loading customers for client: ${widget.client.name}');
      
      // Use the new client customers endpoint that matches "All Customers" data
      final apiService = BackendConnectionManager().apiService;
      final response = await apiService.get('/clients/${widget.client.id}/customers');
      
      if (response['success'] == true) {
        final customerData = response;
        final categories = customerData['categories'] as Map<String, dynamic>? ?? {};
        
        // Combine all customers for display
        final allCustomers = <Map<String, dynamic>>[];
        
        // Add explicitly assigned customers
        if (categories['explicitlyAssigned']?['customers'] != null) {
          final explicit = List<Map<String, dynamic>>.from(categories['explicitlyAssigned']['customers']);
          for (var customer in explicit) {
            customer['categoryType'] = 'Directly Assigned';
            customer['categoryColor'] = 'green';
            allCustomers.add(customer);
          }
        }
        
        // Add domain matched customers
        if (categories['domainMatched']?['customers'] != null) {
          final domain = List<Map<String, dynamic>>.from(categories['domainMatched']['customers']);
          for (var customer in domain) {
            customer['categoryType'] = 'Domain Matched (@${customerData['clientInfo']['domain']})';
            customer['categoryColor'] = 'blue';
            allCustomers.add(customer);
          }
        }
        
        // Add company matched customers
        if (categories['companyMatched']?['customers'] != null) {
          final company = List<Map<String, dynamic>>.from(categories['companyMatched']['customers']);
          for (var customer in company) {
            customer['categoryType'] = 'Company Matched';
            customer['categoryColor'] = 'orange';
            allCustomers.add(customer);
          }
        }
        
        setState(() {
          _companyEmployees = allCustomers;
          _companyStats = {
            'totalCustomers': customerData['totalCount'] ?? 0,
            'explicitlyAssigned': categories['explicitlyAssigned']?['count'] ?? 0,
            'domainMatched': categories['domainMatched']?['count'] ?? 0,
            'companyMatched': categories['companyMatched']?['count'] ?? 0,
          };
          _companyDomain = customerData['clientInfo']['domain'] ?? '';
          _isLoadingEmployees = false;
        });
        
        debugPrint('✅ Loaded ${allCustomers.length} customers for ${widget.client.name}');
        debugPrint('   - Explicitly assigned: ${categories['explicitlyAssigned']?['count'] ?? 0}');
        debugPrint('   - Domain matched: ${categories['domainMatched']?['count'] ?? 0}');
        debugPrint('   - Company matched: ${categories['companyMatched']?['count'] ?? 0}');
      } else {
        debugPrint('❌ Failed to load customers: ${response['message']}');
        setState(() => _isLoadingEmployees = false);
      }
    } catch (e) {
      debugPrint('❌ Error loading customers: $e');
      setState(() => _isLoadingEmployees = false);
    }
  }
  
  // 🎯 FILTER HANDLERS
  void _handleFilterApplied(Map<String, dynamic> filters) {
    setState(() {
      _activeFilters = filters;
    });
  }

  void _handleFilterCleared() {
    setState(() {
      _activeFilters = {};
    });
