class NotificationsScreen extends StatefulWidget {
  const NotificationsScreen({super.key});

  static const String routeName = '/notifications';

  @override
  State<NotificationsScreen> createState() => _NotificationsScreenState();
}

class _NotificationsScreenState extends State<NotificationsScreen> {
  final NotificationService _notificationService = NotificationService();
  
  List<Map<String, dynamic>> _notifications = [];
  bool _isLoading = true;
  String? _errorMessage;
  StreamSubscription<Map<String, dynamic>>? _notificationSubscription;
  int _unreadCount = 0;

  @override
  void initState() {
    super.initState();
    debugPrint('🔔 NotificationsScreen: initState called');
    _loadNotifications();
    _setupRealtimeListener();
  }

  @override
  void dispose() {
    _notificationSubscription?.cancel();
    super.dispose();
  }

  Future<void> _loadNotifications() async {
    debugPrint('🔄 ========================================');
    debugPrint('🔄 LOADING NOTIFICATIONS IN SCREEN');
    debugPrint('🔄 ========================================');
    setState(() {
      _isLoading = true;
      _errorMessage = null;
    });

    try {
      // First, try to get notifications from backend API
      debugPrint('📡 Step 1: Fetching from backend API...');
      final dynamic response = await _notificationService.getNotifications();
      debugPrint('📦 RAW NOTIFICATION Response: $response');
      debugPrint('📦 Response Type: ${response.runtimeType}');
      
      final unreadCount = await _notificationService.getUnreadCount(adminOnly: true);
      
      if (mounted) {
        setState(() {
          // Handle the response structure from NotificationService
          if (response is Map) {
            debugPrint('✅ Response is Map, extracting notifications...');
            
            // The NotificationService returns: { 'success': true, 'notifications': [...], 'pagination': {...} }
            // So we need to check for 'notifications' key specifically
            final notifications = response['notifications'] ?? 
                                 response['data'] ?? 
                                 response['data']?['notifications'] ?? 
                                 [];
            
            debugPrint('📦 Extracted Notifications: $notifications');
            debugPrint('📦 Notifications Type: ${notifications.runtimeType}');
            
            if (notifications is List) {
              _notifications = List<Map<String, dynamic>>.from(notifications);
              debugPrint('✅ Converted to List with ${_notifications.length} items');
            } else {
              _notifications = [];
              debugPrint('⚠️ Notifications is not a List, setting empty');
            }
          } else if (response is List) {
            debugPrint('✅ Response is List directly');
            _notifications = List<Map<String, dynamic>>.from(response);
          } else {
            debugPrint('⚠️ Response is neither Map nor List: ${response.runtimeType}');
            _notifications = [];
          }
          // Filter to show only admin-relevant notifications
          debugPrint('🔍 ========================================');
          debugPrint('🔍 FILTERING ADMIN NOTIFICATIONS');
          debugPrint('🔍 ========================================');
          debugPrint('📊 Total notifications before filter: ${_notifications.length}');
          
          // Log each notification type
          final notificationTypes = <String, int>{};
          for (var notif in _notifications) {
            final type = notif['type']?.toString() ?? 'unknown';
            notificationTypes[type] = (notificationTypes[type] ?? 0) + 1;
          }
          
          debugPrint('📋 Notification types breakdown:');
          notificationTypes.forEach((type, count) {
            debugPrint('   - $type: $count');
          });
          
          // Define admin-relevant types
          const adminTypes = [
            'leave_approved_admin',
            'trip_cancelled',
            'sos_alert',
            'driver_report',
            'vehicle_maintenance',
            'roster_pending',
            'customer_registration',  // Keep customer registration
            'document_expired',  // Document expiry notifications
            'document_expiring_soon',  // Document expiring soon notifications
          ];
          
          debugPrint('\n✅ Admin-relevant types: $adminTypes');
          
          // Filter and log what's being kept/removed
          final filteredOut = <String>[];
          _notifications = _notifications.where((notification) {
            final type = notification['type']?.toString() ?? '';
            final title = notification['title']?.toString() ?? 'No title';
            final isAdmin = adminTypes.contains(type);
            
            if (!isAdmin) {
              filteredOut.add('$type: $title');
            }
            
            return isAdmin;
          }).toList();
          
          debugPrint('\n❌ Filtered out ${filteredOut.length} non-admin notifications:');
          for (var item in filteredOut) {
            debugPrint('   - $item');
          }
          
          debugPrint('\n✅ Kept ${_notifications.length} admin notifications:');
          for (var notif in _notifications) {
            final type = notif['type']?.toString() ?? 'unknown';
            final title = notif['title']?.toString() ?? 'No title';
            final isRead = notif['isRead'] == true || notif['read'] == true;
            debugPrint('   - $type: $title (${isRead ? "read" : "unread"})');
          }
          
          _unreadCount = unreadCount;
          _isLoading = false;
          
          debugPrint('\n📊 FILTER SUMMARY:');
          debugPrint('   Total fetched: ${_notifications.length + filteredOut.length}');
          debugPrint('   Admin notifications: ${_notifications.length}');
          debugPrint('   Filtered out: ${filteredOut.length}');
          debugPrint('   Unread count: $_unreadCount');
          debugPrint('🔍 ========================================\n');
        });
      }
      
      debugPrint('✅ Loaded ${_notifications.length} admin notifications from backend (filtered)');
      debugPrint('📬 Unread count: $_unreadCount');
      
      // Print first notification if available
      if (_notifications.isNotEmpty) {
        debugPrint('📋 First notification: ${_notifications.first}');
      } else {
        debugPrint('⚠️ No notifications found from backend');
      }
      
      // Step 2: Also fetch from Firebase Realtime Database
      debugPrint('🔥 Step 2: Fetching from Firebase RTDB...');
      await _loadFirebaseNotifications();
      
    } catch (e, stackTrace) {
      debugPrint('❌ Error loading notifications: $e');
      debugPrint('❌ Stack trace: $stackTrace');
      if (mounted) {
        setState(() {
          _errorMessage = e.toString();
          _isLoading = false;
        });
      }
    }
  }

  Future<void> _loadFirebaseNotifications() async {
    try {
      final user = FirebaseAuth.instance.currentUser;
      if (user == null) {
        debugPrint('⚠️ No user logged in, skipping Firebase RTDB fetch');
        return;
      }

      debugPrint('🔥 Fetching notifications from: notifications/${user.uid}');
      
      final notificationsRef = FirebaseDatabase.instance.ref('notifications/${user.uid}');
      final snapshot = await notificationsRef.get();

      if (!snapshot.exists) {
        debugPrint('⚠️ No notifications found in Firebase RTDB');
        return;
      }

      final data = snapshot.value;
      if (data == null) {
        debugPrint('⚠️ Firebase RTDB data is null');
        return;
      }

      // Handle both Map and other types
      Map<dynamic, dynamic> notificationMap;
      if (data is Map) {
        notificationMap = data;
      } else {
        debugPrint('⚠️ Firebase RTDB data is not a Map: ${data.runtimeType}');
        return;
      }

      debugPrint('✅ Found ${notificationMap.length} notifications in Firebase RTDB');

      // Convert Firebase notifications to list
      final firebaseNotifications = <Map<String, dynamic>>[];
      notificationMap.forEach((key, value) {
        try {
          if (value is Map) {
            // Convert nested maps properly
            final notification = <String, dynamic>{};
            value.forEach((k, v) {
              if (v is Map) {
                notification[k.toString()] = Map<String, dynamic>.from(v as Map);
              } else {
                notification[k.toString()] = v;
              }
            });
            
            notification['id'] = key.toString();
            notification['_id'] = key.toString();
            notification['read'] = notification['isRead'] ?? false;
            firebaseNotifications.add(notification);
            
            debugPrint('   - ${notification['title']} (${notification['type']})');
          }
        } catch (e) {
          debugPrint('⚠️ Error processing notification $key: $e');
        }
      });

      // Sort by createdAt (newest first)
      firebaseNotifications.sort((a, b) {
        final aTime = DateTime.tryParse(a['createdAt']?.toString() ?? '') ?? DateTime.now();
        final bTime = DateTime.tryParse(b['createdAt']?.toString() ?? '') ?? DateTime.now();
        return bTime.compareTo(aTime);
      });

      if (mounted) {
        setState(() {
          // Merge with existing notifications (avoid duplicates)
          final existingIds = _notifications.map((n) => n['id'] ?? n['_id']).toSet();
          for (var notification in firebaseNotifications) {
            final id = notification['id'] ?? notification['_id'];
            if (!existingIds.contains(id)) {
              _notifications.add(notification);
            }
          }
          
          // Sort all notifications by createdAt
          _notifications.sort((a, b) {
            final aTime = DateTime.tryParse(a['createdAt']?.toString() ?? '') ?? DateTime.now();
            final bTime = DateTime.tryParse(b['createdAt']?.toString() ?? '') ?? DateTime.now();
            return bTime.compareTo(aTime);
          });
          
          _isLoading = false;
        });
      }

      debugPrint('✅ Total notifications after merge: ${_notifications.length}');
    } catch (e, stackTrace) {
      debugPrint('❌ Error loading Firebase notifications: $e');
      debugPrint('   Stack trace: $stackTrace');
    }
  }

  void _setupRealtimeListener() {
    debugPrint('🔔 Setting up real-time notification listener');
    
    _notificationSubscription = _notificationService.onNewNotification.listen(
      (notification) {
        debugPrint('📬 NEW NOTIFICATION IN SCREEN: ${notification['title']}');
        
        if (mounted) {
          setState(() {
            // Add new notification to the top of the list
            _notifications.insert(0, notification);
            if (notification['read'] == false) {
              _unreadCount++;
            }
          });
        }
      },
      onError: (error) {
        debugPrint('❌ Error in notification stream: $error');
      },
    );
  }

  Future<void> _markAsRead(String notificationId, int index) async {
    debugPrint('📝 ========================================');
    debugPrint('📝 MARKING NOTIFICATION AS READ');
    debugPrint('📝 ========================================');
    debugPrint('📝 Notification ID: $notificationId');
    debugPrint('📝 Index: $index');
    
    try {
      final notification = _notifications[index];
      debugPrint('📝 Type: ${notification['type']}');
      debugPrint('📝 Title: ${notification['title']}');
      
      // Only mark as read if it's currently unread
      if (notification['read'] == false || notification['isRead'] == false) {
        // Mark as read in backend API (MongoDB)
        if (!notificationId.startsWith('-')) {
          await _notificationService.markAsRead(notificationId);
          debugPrint('✅ Marked as read in MongoDB: $notificationId');
        }
        
        // ALSO mark as read in Firebase Realtime Database
        final currentUser = FirebaseAuth.instance.currentUser;
        if (currentUser != null) {
          try {
            final notifRef = FirebaseDatabase.instance
                .ref('notifications/${currentUser.uid}/$notificationId');
            await notifRef.update({'isRead': true, 'read': true});
            debugPrint('✅ Marked as read in Firebase RTDB: $notificationId');
          } catch (e) {
            debugPrint('⚠️ Error updating Firebase RTDB: $e');
          }
        }
        
        if (mounted) {
          setState(() {
            _notifications[index]['read'] = true;
            _notifications[index]['isRead'] = true;
            _unreadCount = (_unreadCount - 1).clamp(0, double.infinity).toInt();
          });
          
          // Update the NotificationProvider to refresh the badge count
          try {
            debugPrint('🔔 Refreshing notification badge count...');
            Provider.of<NotificationProvider>(context, listen: false).fetchUnreadNotificationCount(adminOnly: true);
            debugPrint('✅ Badge count refresh initiated');
          } catch (e) {
            debugPrint('⚠️ Could not update NotificationProvider: $e');
          }
        }
        
        debugPrint('✅ Marked notification as read: $notificationId');
        debugPrint('📊 New unread count: $_unreadCount');
      }
    } catch (e) {
      debugPrint('❌ Error marking notification as read: $e');
      if (!notificationId.startsWith('-') && mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Failed to mark as read: $e')),
        );
      }
    }
  }

  Future<void> _markAllAsRead() async {
    try {
      // Mark all as read in backend API
      await _notificationService.markAllAsRead();
      
      // ALSO mark all as read in Firebase Realtime Database
      final currentUser = FirebaseAuth.instance.currentUser;
      if (currentUser != null) {
        try {
          final notificationsRef = FirebaseDatabase.instance
              .ref('notifications/${currentUser.uid}');
          final snapshot = await notificationsRef.get();
          
          if (snapshot.exists) {
            final data = snapshot.value as Map<dynamic, dynamic>;
            final updates = <String, dynamic>{};
            
            data.forEach((key, value) {
              updates['$key/isRead'] = true;
              updates['$key/read'] = true;
            });
            
            await notificationsRef.update(updates);
            debugPrint('✅ Marked all as read in Firebase RTDB');
          }
        } catch (e) {
          debugPrint('⚠️ Error updating Firebase RTDB: $e');
        }
      }
      
      if (mounted) {
        setState(() {
          for (var notification in _notifications) {
            notification['read'] = true;
            notification['isRead'] = true;
          }
          _unreadCount = 0;
        });
        
        // Update the NotificationProvider to refresh the badge count
        try {
          debugPrint('🔔 Refreshing notification badge count...');
          Provider.of<NotificationProvider>(context, listen: false).fetchUnreadNotificationCount(adminOnly: true);
          debugPrint('✅ Badge count refresh initiated');
        } catch (e) {
          debugPrint('⚠️ Could not update NotificationProvider: $e');
        }
      }
      
      debugPrint('✅ Marked all notifications as read');
      
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text('All notifications marked as read'),
            duration: Duration(seconds: 2),
          ),
        );
      }
    } catch (e) {
      debugPrint('❌ Error marking all as read: $e');
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Failed to mark all as read: $e')),
        );
      }
    }
  }

  Future<void> _clearOldNotifications() async {
    // Show confirmation dialog
    final confirmed = await showDialog<bool>(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Clean Up Notifications'),
        content: const Text('This will remove:\n• Read notifications older than 7 days\n• Routine notifications (assignments, updates, etc.)\n\nImportant notifications will be kept. Continue?'),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context, false),
            child: const Text('Cancel'),
          ),
          ElevatedButton(
            onPressed: () => Navigator.pop(context, true),
            style: ElevatedButton.styleFrom(backgroundColor: Colors.red),
            child: const Text('Clean Up'),
          ),
        ],
      ),
    );

    if (confirmed != true) return;

    try {
      debugPrint('🧹 ========================================');
      debugPrint('🧹 CLEARING OLD & NON-ADMIN NOTIFICATIONS');
      debugPrint('🧹 ========================================');
      
      final currentUser = FirebaseAuth.instance.currentUser;
      if (currentUser == null) {
        debugPrint('❌ No current user, aborting');
        return;
      }

      int deletedCount = 0;
      final sevenDaysAgo = DateTime.now().subtract(const Duration(days: 7));
      final nonAdminTypes = ['roster_assigned', 'leave_approved', 'leave_rejected', 'leave_request', 'account_approved'];
      
      debugPrint('📅 Seven days ago: $sevenDaysAgo');
      debugPrint('🚫 Non-admin types to delete: $nonAdminTypes');
      debugPrint('📊 Total notifications to check: ${_notifications.length}\n');
      
      // Delete from MongoDB via API (all notifications, not just Firebase RTDB)
      for (var notification in _notifications) {
        final notifId = notification['_id']?.toString();
        if (notifId == null) continue;
        
        final type = notification['type']?.toString() ?? '';
        final isRead = notification['isRead'] == true || notification['read'] == true;
        final createdAt = DateTime.tryParse(notification['createdAt']?.toString() ?? '');
        
        // Delete if: old + read OR non-admin type
        final shouldDelete = (isRead && createdAt != null && createdAt.isBefore(sevenDaysAgo)) ||
                            nonAdminTypes.contains(type);
        
        if (shouldDelete) {
          try {
            debugPrint('🗑️  Deleting: $type - ${notification['title']} (${isRead ? "old+read" : "non-admin type"})');
            await _notificationService.deleteNotification(notifId);
            deletedCount++;
          } catch (deleteError) {
            debugPrint('❌ Failed to delete $notifId: $deleteError');
          }
        } else {
          debugPrint('✅ Keeping: $type - ${notification['title']}');
        }
      }
      
      debugPrint('\n📊 MongoDB deletion complete: $deletedCount notifications deleted');
      
      // Also delete from Firebase RTDB
      debugPrint('\n🔥 Cleaning Firebase RTDB...');
      final notificationsRef = FirebaseDatabase.instance.ref('notifications/${currentUser.uid}');
      final snapshot = await notificationsRef.once();
      
      if (snapshot.snapshot.exists) {
        final data = snapshot.snapshot.value as Map<dynamic, dynamic>;
        
        for (var entry in data.entries) {
          final notif = entry.value as Map<dynamic, dynamic>;
          final type = notif['type']?.toString() ?? '';
          final isRead = notif['isRead'] == true;
          final createdAt = DateTime.tryParse(notif['createdAt']?.toString() ?? '');
          
          final shouldDelete = (isRead && createdAt != null && createdAt.isBefore(sevenDaysAgo)) ||
                              nonAdminTypes.contains(type);
          
          if (shouldDelete) {
            await notificationsRef.child(entry.key).remove();
          }
        }
      }
      
      debugPrint('\n✅ CLEANUP COMPLETE');
      debugPrint('   Total deleted: $deletedCount');
      debugPrint('🧹 ========================================\n');
      
      // Reload notifications
      await _loadNotifications();
      
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Cleared $deletedCount notifications'),
            backgroundColor: Colors.green,
          ),
        );
      }
    } catch (e) {
      debugPrint('❌ ========================================');
      debugPrint('❌ ERROR CLEARING NOTIFICATIONS');
      debugPrint('❌ ========================================');
      debugPrint('❌ Error: $e');
      debugPrint('❌ ========================================\n');
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Failed to clear notifications: $e')),
        );
      }
    }
  }

