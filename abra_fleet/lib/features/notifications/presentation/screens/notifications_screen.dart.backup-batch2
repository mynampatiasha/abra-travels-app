            if (type == 'customer_registration') ...[
              ElevatedButton.icon(
                style: ElevatedButton.styleFrom(
                  backgroundColor: const Color(0xFF2563EB),
                ),
                icon: const Icon(Icons.person_search),
                label: const Text('View Pending'),
                onPressed: () {
                  Navigator.of(context).pop();
                  Navigator.of(context).pop(); // Close notifications screen
                  // The admin shell will handle navigation to pending customers
                  debugPrint('Navigate to pending customers');
                },
              ),
            ],
            if (type == 'roster_assigned' || type == 'roster_updated') ...[
              ElevatedButton(
                style: ElevatedButton.styleFrom(
                  backgroundColor: Theme.of(context).primaryColor,
                ),
                child: const Text('View Roster'),
                onPressed: () {
                  Navigator.of(context).pop();
                  // TODO: Navigate to roster details
                  debugPrint('Navigate to roster: ${effectiveData?['rosterId']}');
