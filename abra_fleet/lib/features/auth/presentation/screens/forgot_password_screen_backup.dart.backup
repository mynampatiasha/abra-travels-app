                        const SizedBox(height: 8),
                        Text(
                          'Google Sign-In requires additional configuration for web. Add your client ID to web/index.html or configure it in the GoogleSignIn initialization.',
                          style: TextStyle(color: Colors.blue.shade700),
                        ),
                      ],
                    ),
                  ),
                ],
              ],
            ),
          ),
        ),
      ),
    );
  }
}