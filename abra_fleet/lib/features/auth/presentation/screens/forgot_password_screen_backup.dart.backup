// Enhanced password reset system with proper Google Sign-In configuration
import 'package:flutter/material.dart';
import 'package:provider/provider.dart';
import 'package:firebase_auth/firebase_auth.dart';
import 'package:google_sign_in/google_sign_in.dart';
import 'package:flutter/foundation.dart' show kIsWeb;
import 'package:abra_fleet/features/auth/domain/repositories/auth_repository.dart';
import 'package:abra_fleet/features/auth/data/repositories/mock_auth_repository_impl.dart';

class ForgotPasswordScreen extends StatefulWidget {
  const ForgotPasswordScreen({super.key});

  @override
  State<ForgotPasswordScreen> createState() => _ForgotPasswordScreenState();
}

class _ForgotPasswordScreenState extends State<ForgotPasswordScreen> {
  final _formKey = GlobalKey<FormState>();
  final _emailController = TextEditingController();
  final _newPasswordController = TextEditingController();
  final _confirmPasswordController = TextEditingController();
  
  bool _isLoading = false;
  bool _isEmailSelected = true;
  bool _showNewPasswordForm = false;
  String? _verifiedGoogleEmail;
  bool _isGoogleSignInAvailable = false;

  // Proper Google Sign-In initialization
  GoogleSignIn? _googleSignIn;

  @override
  void initState() {
    super.initState();
    _initializeGoogleSignIn();
  }

  void _initializeGoogleSignIn() {
    try {
      // Check if running on web
      if (kIsWeb) {
        // For web, use the same client ID from your Android configuration
        _googleSignIn = GoogleSignIn(
          scopes: ['email', 'profile'],
          clientId: '847585068690-ls16e9oshf9m7obcvameadloltfsv4th.apps.googleusercontent.com',
        );
        _isGoogleSignInAvailable = true;
        print('Google Sign-In initialized for web with client ID');
      } else {
        // For mobile platforms, initialize normally (client ID comes from google-services.json)
        _googleSignIn = GoogleSignIn(
          scopes: ['email', 'profile'],
        );
        _isGoogleSignInAvailable = true;
        print('Google Sign-In initialized for mobile');
      }
    } catch (e) {
      print('Google Sign-In initialization error: $e');
      _isGoogleSignInAvailable = false;
    }
  }

  @override
  void dispose() {
    _emailController.dispose();
    _newPasswordController.dispose();
    _confirmPasswordController.dispose();
    super.dispose();
  }

  // Email-based password reset
  Future<void> _sendEmailResetLink() async {
    if (!_formKey.currentState!.validate()) return;

    setState(() => _isLoading = true);

    final authRepository = Provider.of<AuthRepository>(context, listen: false);
    final scaffoldMessenger = ScaffoldMessenger.of(context);

    try {
      await authRepository.sendPasswordResetEmail(
        email: _emailController.text.trim(),
      );

      if (mounted) {
        scaffoldMessenger.showSnackBar(
          SnackBar(
            content: Column(
              mainAxisSize: MainAxisSize.min,
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text('Password reset email sent to ${_emailController.text.trim()}'),
                const SizedBox(height: 4),
                const Text(
                  'Check your email (including spam folder)',
                  style: TextStyle(fontSize: 12, fontWeight: FontWeight.w500),
                ),
              ],
            ),
            backgroundColor: Colors.green,
            duration: const Duration(seconds: 6),
          ),
        );
        Navigator.pop(context);
      }
    } catch (e) {
      if (mounted) {
        scaffoldMessenger.showSnackBar(
          SnackBar(
            content: Text('Failed to send reset link: ${e.toString().replaceFirst("Exception: ", "")}'),
            backgroundColor: Colors.red,
          ),
        );
      }
    } finally {
      if (mounted) {
        setState(() => _isLoading = false);
      }
    }
  }

  // Improved Google Sign-In verification with better error handling
  Future<void> _verifyWithGoogle() async {
    if (_googleSignIn == null || !_isGoogleSignInAvailable) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text('Google Sign-In is not available'),
          backgroundColor: Colors.orange,
        ),
      );
      return;
    }

    setState(() => _isLoading = true);

    try {
      await _googleSignIn!.signOut();
      
      // For forgot password flow, we need to allow Google sign-in
      // Try silent sign in first, then allow popup if needed
      GoogleSignInAccount? googleUser = await _googleSignIn!.signInSilently();
      
      if (googleUser == null) {
        // If no silent sign in available, do regular sign in for verification
        googleUser = await _googleSignIn!.signIn();
      }
      
      if (googleUser == null) {
        throw Exception('Google Sign-In was cancelled. Please try again.');
      }
      

      print('Google Sign-In successful: ${googleUser.email}');

      // First authenticate with Firebase using Google credentials to get permissions
      final GoogleSignInAuthentication googleAuth = await googleUser.authentication;
      final AuthCredential credential = GoogleAuthProvider.credential(
        accessToken: googleAuth.accessToken,
        idToken: googleAuth.idToken,
      );
      
      // Temporarily sign in to Firebase to check user existence
      final UserCredential userCredential = await FirebaseAuth.instance.signInWithCredential(credential);
      final User? firebaseUser = userCredential.user;
      
      if (firebaseUser == null) {
        await _googleSignIn!.signOut();
        throw Exception('Failed to authenticate with Firebase');
      }
      
      // Now check Firestore document with authenticated user
      final querySnapshot = await FirebaseFirestore.instance
          .collection('users')
          .where('email', isEqualTo: googleUser.email)
          .limit(1)
          .get();
      
      // Sign out from Firebase after verification (we only needed it for permissions)
      await FirebaseAuth.instance.signOut();
      
      if (querySnapshot.docs.isEmpty) {
        // User doesn't exist in Firestore - check if they exist in Firebase Auth
        final methods = await FirebaseAuth.instance.fetchSignInMethodsForEmail(googleUser.email);
        
        if (methods.isEmpty) {
          await _googleSignIn!.signOut();
          throw Exception('This email is not registered in our system. Please sign up first.');
        }

        // User exists in Firebase Auth but not Firestore - create document
        final shouldCreateProfile = await _showProfileCreationDialog(googleUser.email);
        
        if (shouldCreateProfile == true) {
          final role = await _showRoleSelectionDialog();
          if (role != null) {
            await _createUserProfile(googleUser, role);
          } else {
            await _googleSignIn!.signOut();
            throw Exception('Profile creation cancelled');
          }
        } else {
          await _googleSignIn!.signOut();
          throw Exception('Cannot proceed without user profile');
        }
      } else {
        // User exists in Firestore - verify they have a valid role
        final userData = querySnapshot.docs.first.data() as Map<String, dynamic>;
        final userRole = userData['role'] as String?;
        
        if (userRole == null || userRole.isEmpty) {
          await _googleSignIn!.signOut();
          throw Exception('User profile is incomplete. Please contact support.');
        }
        
        print('User found in Firestore with role: $userRole');
        
        // Store the verified Google email and keep user signed in for password update
        _verifiedGoogleEmail = googleUser.email;
        
        // Keep both Google and Firebase sessions active for password update
        // Don't sign out - we need these credentials for the password update
        
        setState(() {
          _showNewPasswordForm = true;
          _isLoading = false;
        });

    } catch (e) {
      print('Google verification error: $e');
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Error: ${e.toString().replaceFirst("Exception: ", "")}'),
            backgroundColor: Colors.red,
          ),
        );
        setState(() => _isLoading = false);
      }
    }
  }

  Future<bool?> _showProfileCreationDialog(String email) async {
    return showDialog<bool>(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Complete Profile'),
        content: Text('Your account ($email) needs a profile to continue. Would you like to create one?'),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(context).pop(false),
            child: const Text('Cancel'),
          ),
          TextButton(
            onPressed: () => Navigator.of(context).pop(true),
            child: const Text('Create Profile'),
          ),
        ],
      ),
    );
  }

  // Add the missing _showRoleSelectionDialog method
  Future<String?> _showRoleSelectionDialog() async {
    return showDialog<String>(
      context: context,
      barrierDismissible: false,
      builder: (BuildContext context) {
        return AlertDialog(
          title: const Text('Select Your Role'),
          content: const Text('Please select your role to complete registration:'),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop('user'),
              child: const Text('User'),
            ),
            TextButton(
              onPressed: () => Navigator.of(context).pop('driver'),
              child: const Text('Driver'),
            ),
            TextButton(
              onPressed: () => Navigator.of(context).pop('admin'),
              child: const Text('Admin'),
            ),
          ],
        );
      },
    );
  }

  Future<void> _createUserProfile(GoogleSignInAccount googleUser, String role) async {
  try {
    // First, sign in the Google user to get their Firebase Auth UID
    final GoogleSignInAuthentication googleAuth = await googleUser.authentication;
    final AuthCredential credential = GoogleAuthProvider.credential(
      accessToken: googleAuth.accessToken,
      idToken: googleAuth.idToken,
    );
    
    final UserCredential userCredential = await FirebaseAuth.instance.signInWithCredential(credential);
    final User? firebaseUser = userCredential.user;
    
    if (firebaseUser == null) {
      throw Exception('Failed to authenticate with Firebase');
    }
    
    final userData = {
      'email': googleUser.email,
      'name': googleUser.displayName ?? '',
      'role': role.toLowerCase().trim(),
      'authProvider': 'google',
      'createdAt': FieldValue.serverTimestamp(),
      'updatedAt': FieldValue.serverTimestamp(),
    };
    
    // Use the Firebase Auth UID as the document ID
    await FirebaseFirestore.instance
        .collection('users')
        .doc(firebaseUser.uid) // Use the actual Firebase Auth UID
        .set(userData);
    
    print('User profile created for: ${googleUser.email} with UID: ${firebaseUser.uid}');
    
  } catch (e) {
    print('Error creating user profile: $e');
    rethrow;
  }
}

  // Helper method to check if user exists by email
  Future<bool> _checkUserExistsByEmail(String email) async {
    final authRepository = Provider.of<AuthRepository>(context, listen: false);
    
    try {
      if (authRepository is MockAuthRepositoryImpl) {
        // For mock repository, check if user exists in mock data
        // You might want to add a proper method for this in your mock repository
        return true; // For demo purposes, assume user exists
      } else {
        // For Firebase: check if user exists
        final methods = await FirebaseAuth.instance.fetchSignInMethodsForEmail(email);
        return methods.isNotEmpty;
      }
    } catch (e) {
      print('Error checking user existence: $e');
      return false;
    }
  }

  // Update password after Google verification
  Future<void> _updatePasswordAfterGoogle() async {
    if (!_formKey.currentState!.validate()) return;

    setState(() => _isLoading = true);

    final authRepository = Provider.of<AuthRepository>(context, listen: false);
    final scaffoldMessenger = ScaffoldMessenger.of(context);

    try {
      final googleEmail = _verifiedGoogleEmail!;
      final newPassword = _newPasswordController.text.trim();
      
      print('Starting password update for: $googleEmail');
      
      if (authRepository is MockAuthRepositoryImpl) {
        // For mock implementation
        await authRepository.updatePasswordByEmail(
          email: googleEmail,
          newPassword: newPassword,
        );
      } else {
        // For Firebase implementation - this is the corrected approach
        
        // Step 1: Use Firebase Auth current user (should be signed in from verification)
        final User? currentFirebaseUser = FirebaseAuth.instance.currentUser;
        
        if (currentFirebaseUser != null && currentFirebaseUser.email == _verifiedGoogleEmail) {
          // User is already authenticated with Firebase from verification step
          print('Using existing Firebase user: ${currentFirebaseUser.email}');
          
          // Step 2: Update password directly using Firebase Auth
          await currentFirebaseUser.updatePassword(newPassword);
          print('Password updated successfully in Firebase Auth');
          
        } else {
          // Fallback: Re-authenticate with Google if Firebase session expired
          if (_googleSignIn != null && _verifiedGoogleEmail != null) {
            try {
              // Get the current Google user (should still be signed in from verification)
              GoogleSignInAccount? googleUser = _googleSignIn!.currentUser;
              
              if (googleUser == null) {
                // Try silent sign in to get the user back
                googleUser = await _googleSignIn!.signInSilently();
              }
              
              if (googleUser == null || googleUser.email != _verifiedGoogleEmail) {
                throw Exception('Please complete Google verification first');
              }
              
              print('Google user obtained: ${googleUser.email}');
              
              // Step 2: Get authentication credentials
              final GoogleSignInAuthentication googleAuth = await googleUser.authentication;
              
              if (googleAuth.accessToken == null || googleAuth.idToken == null) {
                throw Exception('Google authentication expired. Please verify again.');
              }
            
            print('Google tokens obtained successfully');
            
            // Step 3: Create Firebase credential
            final AuthCredential credential = GoogleAuthProvider.credential(
              accessToken: googleAuth.accessToken,
              idToken: googleAuth.idToken,
            );
            
            // Step 4: Sign in to Firebase with Google credentials
            final UserCredential userCredential = await FirebaseAuth.instance.signInWithCredential(credential);
            final User? firebaseUser = userCredential.user;
            
            if (firebaseUser == null) {
              throw Exception('Failed to sign in to Firebase');
            }
            
            print('Firebase sign in successful: ${firebaseUser.email}');
            
            // Step 5: Update the password
            await firebaseUser.updatePassword(newPassword);
            print('Password updated successfully');
            
            // Sign out after successful password update
            await FirebaseAuth.instance.signOut();
            await _googleSignIn!.signOut();
            
            print('Password updated and signed out successfully');
            
          } catch (e) {
            print('Firebase password update error: $e');
            throw Exception('Failed to update password: $e');
          }
        } else {
          throw Exception('Google Sign-In not available');
        }
      }
      
      if (mounted) {
        scaffoldMessenger.showSnackBar(
          const SnackBar(
            content: Text('Password updated successfully! Please login with your new password'),
            backgroundColor: Colors.green,
            duration: Duration(seconds: 4),
          ),
        );
        
        // Navigate to login screen after password update
        // User needs to login with their new password
        Navigator.of(context).popUntil((route) => route.isFirst);
      }
      
    } catch (e) {
      print('Password update error: $e');
      if (mounted) {
        scaffoldMessenger.showSnackBar(
          SnackBar(
            content: Text(e.toString().replaceFirst("Exception: ", "")),
            backgroundColor: Colors.red,
            duration: const Duration(seconds: 5),
          ),
        );
      }
    } finally {
      if (mounted) {
        setState(() => _isLoading = false);
      }
    }
  }

  // Helper method to better handle Google Sign-In state
  Future<GoogleSignInAccount?> _ensureGoogleSignIn() async {
    if (_googleSignIn == null) {
      throw Exception('Google Sign-In not initialized');
    }
    
    try {
      // Try to get current user first
      GoogleSignInAccount? googleUser = _googleSignIn!.currentUser;
      
      if (googleUser != null && googleUser.email == _verifiedGoogleEmail) {
        print('Using existing Google user session');
        return googleUser;
      }
      
      // Try silent sign in
      googleUser = await _googleSignIn!.signInSilently();
      
      if (googleUser != null && googleUser.email == _verifiedGoogleEmail) {
        print('Silent sign in successful');
        return googleUser;
      }
      
      // If we don't have the right user, throw an error instead of using deprecated signIn
      throw Exception('Please complete Google verification with the correct account: $_verifiedGoogleEmail');
      
    } catch (e) {
      print('Error ensuring Google Sign-In: $e');
      rethrow;
    }
  }

