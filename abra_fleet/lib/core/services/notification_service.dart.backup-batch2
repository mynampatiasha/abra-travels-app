  // ========== HELPER METHODS ==========

  /// Get custom notification sound based on notification type
  String? _getNotificationSound(String type) {
    // Only return custom sound if user has it enabled
    if (!_customSoundEnabled) return null;
    
    switch (type) {
      // Leave request notifications for all roles
      case 'leave_request':           // Customer submits leave request
      case 'leave_approved':          // Customer gets approval notification
      case 'leave_rejected':          // Customer gets rejection notification
      case 'leave_approved_admin':    // Admin gets notification to cancel trips
      case 'trip_cancelled':          // Driver gets trip cancellation notification
      // Additional leave-related notifications
      case 'leave_cancelled':         // Customer cancels leave request
      case 'leave_processed':         // Admin completes trip cancellation
        return 'notification'; // This will use notification.mp3
      default:
        return null; // Use default system sound
    }
  }

  /// Check if custom sound should be played for this notification type
  bool _shouldPlayCustomSound(String type) {
    // Only play custom sound if user has it enabled
    if (!_customSoundEnabled) return false;
    
    // Play custom sound for ALL notification types
    return true;
  }

  /// Play custom notification sound for all notifications
  Future<void> _playCustomNotificationSound() async {
    try {
      debugPrint('🔊 Playing custom notification sound');
      
      // Use audioplayers to play the notification sound
      final AudioPlayer audioPlayer = AudioPlayer();
      await audioPlayer.play(AssetSource('Notification.mp3'));
      
      debugPrint('✅ Notification sound played successfully');
    } catch (e) {
      debugPrint('❌ Error playing custom notification sound: $e');
    }
  }

  static String getNotificationIcon(String type) {
    switch (type) {
      case 'roster_assigned':
        return '🚗';
      case 'vehicle_assigned':
        return '🚗';
      case 'roster_updated':
        return '🔄';
      case 'roster_cancelled':
        return '❌';
      // Leave request workflow icons for all roles
      case 'leave_request':
        return '🏖️';  // Customer submits leave request
      case 'leave_approved':
        return '✅';   // Customer gets approval
      case 'leave_rejected':
        return '❌';   // Customer gets rejection
      case 'leave_approved_admin':
        return '📋';   // Admin needs to cancel trips
      case 'trip_cancelled':
        return '🚫';   // Driver gets trip cancellation
      case 'leave_cancelled':
        return '🗑️';   // Customer cancels leave request
      case 'leave_processed':
        return '✔️';   // Admin completes processing
      case 'system':
        return '🔔';
      case 'alert':
        return '⚠️';
      default:
        return '📬';
    }
  }

  static int getNotificationColor(String priority) {
    switch (priority) {
      case 'high':
        return 0xFFFF5252;
      case 'normal':
        return 0xFF2196F3;
      case 'low':
        return 0xFF9E9E9E;
      default:
        return 0xFF2196F3;
    }
  }

  // ✅ UPDATED: Dispose method with observer removal
  void dispose() {
    stopListening();
    _newNotificationController.close();
    _floatingNotificationService.dispose();
    WidgetsBinding.instance.removeObserver(this);
  }
