  // ✅ UPDATED: Improved local notification with custom sounds
  Future<void> _showLocalNotification(Map<String, dynamic> notification) async {
    try {
      final notificationId = notification['id']?.hashCode ?? 
                            DateTime.now().millisecondsSinceEpoch;
      
      final priority = notification['priority'] ?? 'normal';
      final type = notification['type'] ?? 'system';
      
      debugPrint('📱 Showing local notification: ${notification['title']}');
      
      // Determine channel and sound based on notification type
      final isLeaveNotification = _shouldPlayCustomSound(type);
      final channelId = isLeaveNotification ? 'leave_notifications' : 'fleet_notifications';
      final channelName = isLeaveNotification ? 'Leave Request Notifications' : 'Fleet Notifications';
      final soundFile = _getNotificationSound(type);
      
      await _localNotifications.show(
        notificationId,
        notification['title'] ?? 'Fleet Notification',
        notification['body'] ?? '',
        NotificationDetails(
          android: AndroidNotificationDetails(
            channelId,
            channelName,
            channelDescription: isLeaveNotification 
                ? 'Leave request related notifications'
                : 'Real-time fleet management notifications',
            importance: priority == 'high' ? Importance.max : Importance.high,
            priority: priority == 'high' ? Priority.max : Priority.high,
            icon: '@mipmap/ic_launcher',
            color: Color(getNotificationColor(priority)),
            playSound: true,
            sound: soundFile != null ? RawResourceAndroidNotificationSound(soundFile) : null,
            enableVibration: true,
            showWhen: true,
          ),
          iOS: DarwinNotificationDetails(
            presentAlert: true,
            presentBadge: true,
            presentSound: true,
            sound: soundFile != null ? '$soundFile.mp3' : null,
          ),
        ),
        payload: json.encode(notification),
      );
      
      debugPrint('✅ Local notification shown successfully with sound: $soundFile');
    } catch (e) {
      debugPrint('❌ Error showing local notification: $e');
    }
  }

  void stopListening() {
    _notificationSubscription?.cancel();
    _notificationSubscription = null;
    debugPrint('🛑 Realtime notification listener stopped');
  }

  // ========== API METHODS ==========

  Future<String?> _getAuthToken() async {
    final user = _auth.currentUser;
    if (user == null) return null;
    return await user.getIdToken();
  }

  Future<Map<String, String>> _getHeaders() async {
    final token = await _getAuthToken();
    return {
      'Content-Type': 'application/json',
      if (token != null) 'Authorization': 'Bearer $token',
    };
  }

  Future<Map<String, dynamic>> getNotifications({
    int page = 1,
    int limit = 50,
    bool? isRead,
    String? type,
    String? category,
  }) async {
    debugPrint('📡 ========================================');
    debugPrint('📡 FETCHING NOTIFICATIONS FROM BACKEND');
    debugPrint('📡 ========================================');
    debugPrint('   Page: $page');
    debugPrint('   Limit: $limit');
    debugPrint('   IsRead filter: $isRead');
    debugPrint('   Type filter: $type');
    debugPrint('   Category filter: $category');
    
    try {
      final user = _auth.currentUser;
      if (user == null) {
        debugPrint('❌ No user logged in');
        return {
          'success': false,
          'message': 'User not logged in',
        };
      }

      final queryParams = {
        'page': page.toString(),
        'limit': limit.toString(),
        'userId': user.uid, // ✅ Filter by user ID
        if (isRead != null) 'isRead': isRead.toString(),
        if (type != null) 'type': type,
        if (category != null) 'category': category,
      };

      final uri = Uri.parse('${ApiConfig.baseUrl}/api/notifications')
          .replace(queryParameters: queryParams);
      
      debugPrint('   URL: $uri');

      final response = await http.get(uri, headers: await _getHeaders());
      
      debugPrint('   Response Status: ${response.statusCode}');
      debugPrint('   Response Body Length: ${response.body.length} chars');

      if (response.statusCode == 200) {
        final data = json.decode(response.body);
        final notifications = data['data']['notifications'] ?? [];
        final pagination = data['data']['pagination'] ?? {};
        
        debugPrint('✅ Successfully fetched notifications');
        debugPrint('   Total notifications: ${notifications.length}');
        debugPrint('   User: ${user.email}');
        
        // Log first few notifications for debugging
        if (notifications.isNotEmpty) {
          debugPrint('   First notification:');
          final first = notifications[0];
          debugPrint('     - Title: ${first['title']}');
          debugPrint('     - Type: ${first['type']}');
          debugPrint('     - Read: ${first['isRead'] ?? first['read']}');
          debugPrint('     - Created: ${first['createdAt']}');
        }
        
        return {
          'success': true,
          'notifications': notifications,
          'pagination': pagination,
        };
      } else {
        final error = json.decode(response.body);
        debugPrint('❌ Backend returned error: ${response.statusCode}');
        debugPrint('   Error message: ${error['message']}');
        return {
          'success': false,
          'message': error['message'] ?? 'Failed to fetch notifications',
        };
      }
    } catch (e, stackTrace) {
      debugPrint('❌ Error fetching notifications: $e');
      debugPrint('   Stack trace: $stackTrace');
      return {
        'success': false,
        'message': 'Network error: $e',
      };
    }
  }

